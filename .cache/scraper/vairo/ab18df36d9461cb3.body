dth":1080,"height":1080}],"options":[{"name":"Talle","position":1,"values":["S","M","L","XL","XXL"]}]},{"id":9045385773261,"title":"Campera Light Moove Gris Claro","handle":"campera-light-moove-gris-claro","body_html":"\u003cp\u003e\u003cstrong\u003eCampera con capucha y cierre alto al cuello.\u003c\/strong\u003e Tejido flexible (85% poliéster, 15% algodón, 3% elastano) y detalles termosellados que le dan un estilo técnico y moderno.\u003c\/p\u003e\n\u003cdiv class=\"tabs-minimal\"\u003e\n  \u003cinput checked id=\"tab1\" name=\"tabs\" type=\"radio\"\u003e\n  \u003cinput id=\"tab2\" name=\"tabs\" type=\"radio\"\u003e\n  \u003cdiv class=\"tab-labels\"\u003e\n    \u003clabel for=\"tab1\"\u003eTALLES\u003c\/label\u003e\n    \u003clabel for=\"tab2\"\u003eDESCRIPCIÓN\u003c\/label\u003e\n  \u003c\/div\u003e\n  \u003cdiv class=\"tab-content\"\u003e\n    \u003cdiv id=\"content1\" style=\"text-align:center;\"\u003e\n      \u003c!-- Solo la mini previsualización --\u003e\n      \u003cimg src=\"https:\/\/vairo.com\/padel\/wp-content\/uploads\/2025\/07\/CONJUNTO-HODDIE.jpg\" alt=\"Guía de Talles\" style=\"max-width:180px; width:100%; height:auto; border-radius:8px; margin-top:10px; box-shadow:0 2px 8px rgba(0,0,0,0.07); cursor:pointer;\" id=\"previewSizeGuide\"\u003e\n    \u003c\/div\u003e\n    \u003c!-- DESCRIPCIÓN --\u003e\n    \u003cdiv id=\"content2\"\u003e\n      \u003cp\u003e\n        Campera deportiva confeccionado en una mezcla de 85% poliéster, 15% algodón y 3% elastano, que brinda comodidad, elasticidad y abrigo. Su diseño incluye capucha y cierre alto hasta el cuello, ideal para proteger del viento o el frío. Los detalles de termosellado en los cierres le otorgan un look moderno y técnico. Perfecto para entrenamientos al aire libre o para un estilo urbano y relajado con un toque de sofisticación.\n      \u003c\/p\u003e\n    \u003c\/div\u003e\n  \u003c\/div\u003e\n\u003c\/div\u003e\n\n\u003c!-- Modal de Guía de Talles CENTRADO y mobile friendly --\u003e\n\u003cdiv id=\"sizeGuideModal\" style=\"display:none; position:fixed; z-index:9999; left:0; top:0; width:100vw; height:100vh; background:rgba(0,0,0,0.6); align-items:center; justify-content:center;\"\u003e\n  \u003cdiv id=\"sizeGuideContent\" style=\"background:#fff; max-width:90vw; max-height:90vh; padding:20px; border-radius:8px; position:relative; text-align:center; box-sizing:border-box;\"\u003e\n    \u003cbutton id=\"closeSizeGuideBtn\" style=\"position:absolute; top:10px; right:10px; background:none; border:none; font-size:24px; cursor:pointer;\"\u003e×\u003c\/button\u003e\n    \u003cimg src=\"https:\/\/vairo.com\/padel\/wp-content\/uploads\/2025\/07\/CONJUNTO-HODDIE.jpg\" alt=\"Guía de Talles Ampliada\" style=\"max-width:80vw; max-height:70vh; width:100%; height:auto; border-radius:8px;\"\u003e\n  \u003c\/div\u003e\n\u003c\/div\u003e\n\n\u003cscript\u003e\n  document.addEventListener('DOMContentLoaded', function () {\n    var modal = document.getElementById('sizeGuideModal');\n    var previewImg = document.getElementById('previewSizeGuide');\n    var closeBtn = document.getElementById('closeSizeGuideBtn');\n\n    function openModal() {\n      modal.style.display = 'flex';\n    }\n    function closeModal() {\n      modal.style.display = 'none';\n    }\n\n    if(previewImg) previewImg.onclick = openModal;\n    if(closeBtn) closeBtn.onclick = closeModal;\n\n    if(modal) {\n      modal.addEventListener('click', function (e) {\n        if (e.target === modal) {\n          closeModal();\n        }\n      });\n    }\n  });\n\u003c\/script\u003e","published_at":"2025-08-06T15:02:42-03:00","created_at":"2025-08-05T16:18:15-03:00","updated_at":"2026-06-12T15:10:32-03:00","vendor":"Vairo Padel","product_type":"Indumentaria","tags":["Campera con cierre","Campera de media estación","Campera deportiva","Hombre"],"variants":[{"id":48359204126925,"title":"S","option1":"S","option2":null,"option3":null,"sku":"201051030 0234","requires_shipping":true,"taxable":true,"featured_image":null,"