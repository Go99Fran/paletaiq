\u003c\/span\u003eAdaptables al sol, neblina, lluvia o noche.\u003c\/li\u003e\n\u003cli\u003e\u003cstrong\u003eAptas para competición, entrenamiento, ruta o montaña.\u003c\/strong\u003e\u003c\/li\u003e\n\u003cli\u003e\n\u003cstrong\u003eIncluye:\u003c\/strong\u003e\u003cspan\u003e \u003c\/span\u003eMontura, lente montada, lente de recambio, estuche rígido Vairo, paño de microfibra y manual de certificaciones.\u003c\/li\u003e\n\u003c\/ul\u003e\n\u003cdiv class=\"tabs-minimal\"\u003e\n\u003cinput type=\"radio\" name=\"tabs\" id=\"tab1\" checked\u003e \u003cinput type=\"radio\" name=\"tabs\" id=\"tab2\"\u003e\n\u003cdiv class=\"tab-labels\"\u003e\n\u003clabel for=\"tab1\"\u003eCARACTERÍSTICAS\u003c\/label\u003e \u003clabel for=\"tab2\"\u003eTECNOLOGÍA\u003c\/label\u003e\n\u003c\/div\u003e\n\u003cdiv class=\"tab-content\"\u003e\n\u003cdiv id=\"content1\"\u003e\n\u003cul class=\"list-chevron prose\"\u003e\n\u003cli\u003e\n\u003cstrong\u003eMaterial:\u003c\/strong\u003e\u003cspan\u003e \u003c\/span\u003eLente de\u003cspan\u003e \u003c\/span\u003e\u003cstrong\u003epolicarbonato puro\u003c\/strong\u003e\u003cspan\u003e \u003c\/span\u003econ\u003cspan\u003e \u003c\/span\u003e\u003cstrong\u003etecnología REVO\u003c\/strong\u003e.\u003c\/li\u003e\n\u003cli\u003e\n\u003cstrong\u003eProtección:\u003c\/strong\u003e\u003cspan\u003e \u003c\/span\u003e\u003cstrong\u003eUV400 total\u003c\/strong\u003e\u003cspan\u003e \u003c\/span\u003e(bloquea\u003cspan\u003e \u003c\/span\u003e\u003cstrong\u003eUVA\u003c\/strong\u003e,\u003cspan\u003e \u003c\/span\u003e\u003cstrong\u003eUVB\u003c\/strong\u003e\u003cspan\u003e \u003c\/span\u003ey luz dañina).\u003c\/li\u003e\n\u003cli\u003e\n\u003cstrong\u003eResistencia:\u003c\/strong\u003e\u003cspan\u003e \u003c\/span\u003eAlta resistencia a impactos (\u003cstrong\u003eanti-shock\u003c\/strong\u003e).\u003c\/li\u003e\n\u003cli\u003e\n\u003cstrong\u003eTransmisión de luz:\u003c\/strong\u003e\u003cspan\u003e \u003c\/span\u003eDel\u003cspan\u003e \u003c\/span\u003e\u003cstrong\u003e8% al 93%\u003c\/strong\u003e\u003cspan\u003e \u003c\/span\u003esegún el tipo de lente.\u003c\/li\u003e\n\u003cli\u003e\n\u003cstrong\u003eLentes intercambiables:\u003c\/strong\u003e\u003cspan\u003e \u003c\/span\u003eAdaptables a distintas condiciones.\u003c\/li\u003e\n\u003cli\u003e\n\u003cstrong\u003eMontura ergonómica:\u003c\/strong\u003e\u003cspan\u003e \u003c\/span\u003eLente envolvente y\u003cspan\u003e \u003c\/span\u003e\u003cstrong\u003evisión periférica\u003c\/strong\u003e.\u003c\/li\u003e\n\u003cli\u003e\n\u003cstrong\u003ePatillas antideslizantes\u003c\/strong\u003e\u003cspan\u003e \u003c\/span\u003ey\u003cspan\u003e \u003c\/span\u003e\u003cstrong\u003epads nasales\u003c\/strong\u003e\u003cspan\u003e \u003c\/span\u003econ ventilación superior.\u003c\/li\u003e\n\u003cli\u003e\n\u003cstrong\u003ePeso ligero\u003c\/strong\u003e\u003cspan\u003e \u003c\/span\u003ey gran confort.\u003cbr\u003e\n\u003c\/li\u003e\n\u003c\/ul\u003e\n\u003c\/div\u003e\n\u003c!-- TECNOLOGÍA --\u003e\n\u003cdiv id=\"content2\"\u003e\n\u003cul\u003e\n\u003cli\u003e\n\u003cstrong\u003eDiseño de 7 capas:\u003c\/strong\u003e\u003cspan\u003e \u003c\/span\u003eLentes multicapa para mayor protección y durabilidad.\u003c\/li\u003e\n\u003cli\u003e\n\u003cstrong\u003ePolarizado real:\u003c\/strong\u003e\u003cspan\u003e \u003c\/span\u003eElimina reflejos y reduce la fatiga visual.\u003c\/li\u003e\n\u003cli\u003e\n\u003cstrong\u003eTecnología REVO:\u003c\/strong\u003e\u003cspan\u003e \u003c\/span\u003eMejora la visión y protege contra la luz intensa.\u003c\/li\u003e\n\u003cli\u003e\n\u003cstrong\u003eMontura ergonómica:\u003c\/strong\u003e\u003cspan\u003e \u003c\/span\u003eAjuste óptimo y cómodo para largas jornadas.\u003c\/li\u003e\n\u003cli\u003e\n\u003cstrong\u003eVentilación superior:\u003c\/strong\u003e\u003cspan\u003e \u003c\/span\u003eEvita el empañamiento y mejora el flujo de aire.\u003cbr\u003e\n\u003c\/li\u003e\n\u003c\/ul\u003e\n\u003c\/div\u003e\n\u003c\/div\u003e\n\u003c\/div\u003e","published_at":"2026-05-04T16:21:34-03:00","created_at":"2025-11-13T15:27:01-03:00","updated_at":"2026-06-12T15:10:32-03:00","vendor":"Vairo Padel","product_type":"Accesorios","tags":[],"variants":[{"id":48483959800013,"title":"Default Title","option1":"Default Title","option2":null,"option3":null,"sku":"201101170","requires_shipping":true,"taxable":true,"featured_image":null,"available":true,"price":"143000.00","grams":0,"compare_at_price":"0.00","position":1,"product_id":9090223079629,"created_at":"2025-11-13T15:27:01-03:00","updated_at":"2026-06-12T15:10:32-03:00"}],"images":[{"id":54632793997517,"created_at":"2025-11-13T12:46:15-03:00","position":1,"updated_at":"2025-11-13T12:46:17-03:00","product_id":9090223079629,"variant_ids":[],"src":"https:\/\/cdn.shopify.com\/s\/files\/1\/0653\/4745\/3133\/files\/download_6f87ad92-956c-411d-a174-6c62a8548806.webp?v=1763048777","width":1080,"height":1080},{"id":54635050205389,"created_at":"2025-11-14T14:23:57-03:00","position":2,"updated_at":"2025-11-14T14:23:58-03:00","product_id":9090223079629,"variant_ids":[],"src":"https:\/\/cdn.shopify.com\/s\/files\/1\/0653\/4745\/3133\/files\/Lentes_Thunder_Policromatico_-_01.webp?v=1763141038","width":1080,"height":1080},{"id":54635050303693,"created_at":"2025-11-14T14:23:57-03:00","position":3,"updated_at":"2025-11-14T14:23:58-03:00","product_id":9090223079629,"variant_ids":[],"src":"https:\/\/cdn.shopify.com\/s\/files\/1\/0653\/4745\/3133\/files\/Lentes_Thunder_Policromatico_-_02.webp?v=1763141038","width":1080,"height":1080},{"id":54635050336461,"created_at":"2025-11-14T14:23:57-03:00","position":4,"updated_at":"2025-11-14T14:23:58-03:00","product_id":9090223079629,"variant_ids":[],"src":"https:\/\/cdn.shopify.com\/s\/files\/1\/0653\/4745\/3133\/files\/Lentes_Thunder_Policromatico_-_03.webp?v=1763141038","width":1080,"height":1080},{"id":54635050369229,"created_at":"2025-11-14T14:23:57-03:00","position":5,"updated_at":"2025-11-14T14:23:58-03:00","p