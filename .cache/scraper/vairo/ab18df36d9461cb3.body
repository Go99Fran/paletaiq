sa","body_html":"\u003cp data-start=\"29\" data-end=\"286\"\u003eLas nuevas \u003cstrong\u003ePelotas Vairo Pro Rosa\u003c\/strong\u003e combinan \u003cstrong\u003eexcelente rebote, gran durabilidad y máxima performance en cada punto\u003c\/strong\u003e. Su color rosa de alta visibilidad \u003cstrong\u003emejora el seguimiento de la pelota en juego y aporta un estilo único dentro de la cancha\u003c\/strong\u003e. Fabricadas con materiales premium, ofrecen un rendimiento constante y profesional.\u003c\/p\u003e","published_at":"2026-05-21T15:30:35-03:00","created_at":"2026-05-21T09:11:33-03:00","updated_at":"2026-06-12T15:10:32-03:00","vendor":"Vairo","product_type":"","tags":["Accesorios \u003e Pelotas"],"variants":[{"id":48567003578573,"title":"Default Title","option1":"Default Title","option2":null,"option3":null,"sku":"611031004","requires_shipping":true,"taxable":true,"featured_image":null,"available":true,"price":"19000.00","grams":200,"compare_at_price":"0.00","position":1,"product_id":9114274365645,"created_at":"2026-05-21T09:11:33-03:00","updated_at":"2026-06-12T15:10:32-03:00"}],"images":[{"id":55025778294989,"created_at":"2026-05-22T10:02:51-03:00","position":1,"updated_at":"2026-05-22T10:02:52-03:00","product_id":9114274365645,"variant_ids":[],"src":"https:\/\/cdn.shopify.com\/s\/files\/1\/0653\/4745\/3133\/files\/PELOTITASROSAS.jpg?v=1779454972","width":1000,"height":1000},{"id":55025777639629,"created_at":"2026-05-22T10:02:40-03:00","position":2,"updated_at":"2026-05-22T10:02:41-03:00","product_id":9114274365645,"variant_ids":[],"src":"https:\/\/cdn.shopify.com\/s\/files\/1\/0653\/4745\/3133\/files\/ChatGPTImage22may2026_08_49_27.png?v=1779454961","width":1254,"height":1254}],"options":[{"name":"Title","position":1,"values":["Default Title"]}]},{"id":9099975786701,"title":"Polo Gala","handle":"polo-gala","body_html":"\u003cdiv class=\"tabs-minimal\"\u003e\n\u003cinput checked id=\"tab1\" name=\"tabs\" type=\"radio\"\u003e \u003cinput id=\"tab2\" name=\"tabs\" type=\"radio\"\u003e\n\u003cdiv class=\"tab-labels\"\u003e\n\u003clabel for=\"tab1\"\u003eMI TALLE\u003c\/label\u003e \u003clabel for=\"tab2\"\u003eTECNOLOGÍA\u003c\/label\u003e\n\u003c\/div\u003e\n\u003cdiv class=\"tab-content\"\u003e\n\u003c!-- TALLES --\u003e\n\u003cdiv id=\"content1\"\u003e\u003cbutton style=\"background: none; border: none; color: #000; font-size: 14px; text-decoration: underline; cursor: pointer;\"\u003e Ver Guía de Talles \u003c\/button\u003e\u003c\/div\u003e\n\u003c!-- TECNOLOGÍA --\u003e\n\u003cdiv id=\"content2\"\u003e\n\u003cul\u003e\n\u003cli\u003e\n\u003cstrong\u003eSET POLYESTER:\u003c\/strong\u003e Fibra sintética liviana con resistencia al rasgado que absorbe menos humedad para una mejor higiene.\u003c\/li\u003e\n\u003cli\u003e\n\u003cstrong\u003eULTRA LIGHT:\u003c\/strong\u003e Tejido ultra liviano de alto rendimiento.\u003c\/li\u003e\n\u003cli\u003e\n\u003cstrong\u003eAIR TECH:\u003c\/strong\u003e Tejido diseñado para permitir el máximo de circulación de aire, reduciendo así el calor y la humedad.\u003c\/li\u003e\n\u003c\/ul\u003e\n\u003c\/div\u003e\n\u003c\/div\u003e\n\u003c\/div\u003e","published_at":"2026-01-20T08:45:13-03:00","created_at":"2026-01-14T13:58:54-03:00","updated_at":"2026-06-12T15:10:32-03:00","vendor":"Vairo","product_type":"","tags":["Fucsia","Mujer","Ropa Deportiva"],"variants":[{"id":48522324476109,"title":"m","option1":"m","option2":null,"option3":null,"sku":"201091018 0303","requires_shipping":true,"taxable":true,"featured_image":null,"available":true,"price":"95000.00","grams":400,"compare_at_price":"0.00","position":1,"product_id":9099975786701,"created_at":"2026-01-14T13:58:54-03:00","updated_at":"2026-06-12T15:10:32-03:00"},{"id":48522324508877,"title":"l","option1":"l","option2":null,"option3":null,"sku":"201091018  0403","requires_shipping":true,"taxable":true,"featured_image":null,"available":true,"price":"95000.00","grams":400,"compare_at_price":"0.00","position":2,"product_id":9099975786701,"created_at":"2026-01-14T13:58:54-03:00","updated_at":"2026-06-12T15:10:32-03:00"}],"images":[{"id":54950323388621,"created_at":"2026-04-14T12:42:40-03:00","position":1,"updated_at":"2026-04-14T12:42:48-03:00","product_id":9099975786701,"variant_ids":[],"src":"https:\/\/cdn.shopify.com\/s\/files\/1\/0653\/4745\/3133\/files\/FOTOSPARAINDUMENTARIAWEB06.jpg?v=1776181368","width":1000,"height":1000},{"id":54741294022861,"created_at":"2026-01-14T15:11:30-03:00","position":2,"updated_at":"2026-01-14T15:11:31-03:00","product_id":9099975786701,"variant_ids":[],"src":"https:\/\/cdn.shopify.com\/s\/files\/1\/0653\/4745\/3133\/files\/POLOGALA.jpg?v=1768414291","width":1080,"height":1080},{"id":54950323355853,"created_at":"2026-04-14T12:41:19-03:00","position":3,"updated_at":"2026-04-14T12:42:48-03:00","product_id":9099975786701,"variant_ids":[],"src":"https:\/\/cdn.shopify.com\/s\/files\/1\/0653\/4745\/3133\/files\/FOTOSPARAINDUMENTARIAWEB01.jpg?v=1776181368","width":1000,"height":1000}],"options":[{"name":"Talle","position":1,"values":["m","l"]}]},{"id":9032069382349,"title":"Power Protector","handle":"power-protector","body_html":"\u003cp\u003e\u003cstrong\u003ePower Protector\u003c\/strong\u003e es el compañero ideal para tu pala de pádel, diseñado para quienes buscan protección sin sacrificar el rendimiento.\u003c\/p\u003e\n\n\u003cdiv class=\"tabs-minimal\"\u003e\n  \u003cinput checked id=\"tab1\" name=\"tabs\" type=\"radio\"\u003e \n  \u003cinput id=\"tab2\" name=\"tabs\" type=\"radio\"\u003e\n  \u003cdiv class=\"tab-labels\"\u003e\n    \u003clabel for=\"tab1\"\u003eCARACTERÍSTICAS\u003c\/label\u003e\n    \u003clabel for=\"tab2\"\u003eTECNOLOGÍA\u003c\/label\u003e\n  \u003c\/div\u003e\n  \u003cdiv class=\"tab-content\"\u003e\n    \u003c!-- CARACTERÍSTICAS --\u003e\n    \u003cdiv id=\"content1\"\u003e\n      \u003cul\u003e\n        \u003cli\u003eProtector de marco para pala de pádel con acabado rugoso.\u003c\/li\u003e\n        \u003cli\u003eMayor seguridad y potencia durante el juego.\u003c\/li\u003e\n        \u003cli\u003eProtege contra golpes y rozaduras, manteniendo tu pala como nueva.\u003c\/li\u003e\n        \u003cli\u003ePeso ultraligero de solo 29 gramos: no altera el balance ni el rendimiento.\u003c\/li\u003e\n      \u003c\/ul\u003e\n    \u003c\/div\u003e\n    \u003c!-- TECNOLOGÍA --\u003e\n    \u003cdiv id=\"content2\"\u003e\n      \u003cul\u003e\n        \u003cli\u003e\n          \u003cstrong\u003eTextura 3D:\u003c\/strong\u003e Ofrece excelente adherencia y agarre para un control óptimo en cada golpe.\n        \u003c\/li\u003e\n        \u003cli\u003e\n          \u003cstrong\u003eSilicon Tech:\u003c\/strong\u003e Tecnología avanzada que potencia la fijación y protege el marco.\n        \u003c\/li\u003e\n        \u003cli\u003e\n          \u003cstrong\u003eAdhesivo 3M:\u003c\/strong\u003e Alta calidad y durabilidad; el protector se mantiene firme durante todo el partido.\n        \u003c\/li\u003e\n      \u003c\/ul\u003e\n    \u003c\/div\u003e\n  \u003c\/div\u003e\n\u003c\/div\u003e\n","published_at":"2025-07-03T09:02:53-03:00","created_at":"2025-07-03T09:03:00-03:00","updated_at":"2026-06-12T15:10:32-03:00","vendor":"Vairo","product_type":"Accesorios","tags":["Accesorios \u003e Protectores","untagged"],"variants":[{"id":48268919931085,"title":"amarillo","option1":"amarillo","option2":null,"option3":null,"sku":"611021021 01","requires_shipping":true,"taxable":true,"featured_image":{"id":54215407599821,"product_id":9032069382349,"position":4,"created_at":"2025-07-03T09:03:01-03:00","updated_at":"2025-07-03T09:03:00-03:00","alt":null,"width":800,"height":800,"src":"https:\/\/cdn.shopify.com\/s\/files\/1\/0653\/4745\/3133\/files\/power-protector-amarillo.png?v=1751544180","variant_ids":[48268919931085]},"available":true,"price":"14000.00","grams":400,"compare_at_price":"0.00","position":1,"product_id":9032069382349,"created_at":"2025-07-03T09:03:01-03:00","updated_at":"2026-06-12T15:10:32-03:00"},{"id":48268919963853,"title":"naran