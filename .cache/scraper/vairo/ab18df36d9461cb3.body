n        \u003cli\u003e\n\u003cstrong\u003eTextura melange:\u003c\/strong\u003e Brinda un aspecto moderno y diferenciador.\u003c\/li\u003e\n        \u003cli\u003e\n\u003cstrong\u003eLibertad de movimiento:\u003c\/strong\u003e La mezcla de materiales permite flexibilidad y comodidad en cada movimiento.\u003c\/li\u003e\n        \u003cli\u003e\n\u003cstrong\u003eDiseño versátil:\u003c\/strong\u003e Perfecto tanto para actividades deportivas como para uso casual.\u003c\/li\u003e\n      \u003c\/ul\u003e\n    \u003c\/div\u003e\n  \u003c\/div\u003e\n\u003c\/div\u003e\n","published_at":"2025-07-03T09:04:34-03:00","created_at":"2025-07-03T09:04:36-03:00","updated_at":"2026-06-12T15:10:32-03:00","vendor":"Vairo","product_type":"","tags":["Ropa Deportiva \u003e Man \u003e Shorts","untagged"],"variants":[{"id":48268923928781,"title":"s","option1":"s","option2":null,"option3":null,"sku":"215001010 0303","requires_shipping":true,"taxable":true,"featured_image":null,"available":true,"price":"49000.00","grams":180,"compare_at_price":"0.00","position":1,"product_id":9032070136013,"created_at":"2025-07-03T09:04:36-03:00","updated_at":"2026-06-12T15:10:32-03:00"},{"id":48268923961549,"title":"m","option1":"m","option2":null,"option3":null,"sku":"215001010 0304","requires_shipping":true,"taxable":true,"featured_image":null,"available":false,"price":"49000.00","grams":180,"compare_at_price":"0.00","position":2,"product_id":9032070136013,"created_at":"2025-07-03T09:04:36-03:00","updated_at":"2026-06-12T15:10:32-03:00"},{"id":48268923994317,"title":"l","option1":"l","option2":null,"option3":null,"sku":"215001010 0305","requires_shipping":true,"taxable":true,"featured_image":null,"available":true,"price":"49000.00","grams":180,"compare_at_price":"0.00","position":3,"product_id":9032070136013,"created_at":"2025-07-03T09:04:36-03:00","updated_at":"2026-06-12T15:10:32-03:00"},{"id":48268924027085,"title":"xl","option1":"xl","option2":null,"option3":null,"sku":"215001010 0306","requires_shipping":true,"taxable":true,"featured_image":null,"available":true,"price":"49000.00","grams":180,"compare_at_price":"0.00","position":4,"product_id":9032070136013,"created_at":"2025-07-03T09:04:36-03:00","updated_at":"2026-06-12T15:10:32-03:00"},{"id":48489231974605,"title":"xxl","option1":"xxl","option2":null,"option3":null,"sku":"215001010 0307","requires_shipping":true,"taxable":true,"featured_image":null,"available":false,"price":"49000.00","grams":180,"compare_at_price":"0.00","position":5,"product_id":9032070136013,"created_at":"2025-11-20T09:55:31-03:00","updated_at":"2026-06-12T15:10:32-03:00"}],"images":[{"id":54215416414413,"created_at":"2025-07-03T09:04:36-03:00","position":1,"updated_at":"2025-07-03T09:04:36-03:00","product_id":9032070136013,"variant_ids":[],"src":"https:\/\/cdn.shopify.com\/s\/files\/1\/0653\/4745\/3133\/files\/SHORT-ACE-GRIS-01.jpg?v=1751544276","width":1080,"height":1080},{"id":54215416447181,"created_at":"2025-07-03T09:04:36-03:00","position":2,"updated_at":"2025-07-03T09:04:36-03:00","product_id":9032070136013,"variant_ids":[],"src":"https:\/\/cdn.shopify.com\/s\/files\/1\/0653\/4745\/3133\/files\/SHORT-ACE-GRIS-02.jpg?v=1751544276","width":1080,"height":1080}],"options":[{"name":"Talle","position":1,"values":["s","m","l","xl","xxl"]}]},{"id":9032069939405,"title":"Short Pro Azul","handle":"short-pro-azul","body_html":"\u003cp\u003e\u003cstrong\u003eEl \"Short Pro\"\u003c\/strong\u003e es una prenda diseñada específicamente para actividades deportivas como el pádel y otros deportes, con un enfoque en la comodidad, el rango de movimiento y la practicidad. Los bolsillos amplios y los detalles en vinilo añaden características funcionales y estilísticas que podrían mejorar tu experiencia deportiva.\u003c\/p\u003e\n\n\u003cdiv class=\"tabs-minimal\"\u003e\n  \u003cinput checked id=\"tab1\" name=\"tabs\" type=\"radio\"\u003e\n  \u003cinput id=\"tab2\" name=\"tabs\" type=\"radio\"\u003e\n  \u003cdiv class=\"tab-labels\"\u003e\n    \u003clabel for=\"tab1\"\u003eMI TALLE\u003c\/label\u003e\n    \u003clabel for=\"tab2\"\u003eDESCRIPCIÓN\u003c\/label\u003e\n  \u003c\/div\u003e\n  \u003cdiv class=\"tab-content\"\u003e\n    \u003c!-- TALLES --\u003e\n    \u003cdiv id=\"content1\"\u003e\n   \n      \u003cbutton onclick=\"document.getElementById('sizeGuideModal').style.display='block'\" style=\"background:none; border:none; color:#000; font-size:14px; text-decoration:underline; cursor:pointer;\"\u003e\n        Ver Guía de Talles\n      \u003c\/button\u003e\n    \u003c\/div\u003e\n    \u003c!-- DESCRIPCIÓN --\u003e\n    \u003cdiv id=\"content2\"\u003e\n      \u003cul\u003e\n        \u003cli\u003e\n\u003cstrong\u003eMaterial de Microfibra Estirable:\u003c\/strong\u003e El short está confeccionado en microfibra, un material ligero y suave que proporciona comodidad durante la actividad física. La cualidad estirable de la tela puede permitir un rango de movimiento óptimo mientras juegas al pádel u otros deportes.\u003c\/li\u003e\n        \u003cli\u003e\n\u003cstrong\u003eDiseño Deportivo:\u003c\/strong\u003e El diseño del “Short Pro” está pensado para actividades deportivas como el pádel. Puede tener un corte que se adapte bien a movimientos rápidos y dinámicos, permitiendo que te muevas libremente en la cancha.\u003c\/li\u003e\n        \u003cli\u003e\n\u003cstrong\u003eBolsillos Amplios:\u003c\/strong\u003e Prácticos para llevar pelotas de pádel, llaves, pañuelo, etc.\u003c\/li\u003e\n        \u003cli\u003e\n\u003cstrong\u003eDetalles en Vinilo:\u003c\/strong\u003e Agregan un toque estilizado y moderno, además de resistencia adicional.\u003c\/li\u003e\n        \u003cli\u003e\n\u003cstrong\u003eMultideporte:\u003c\/strong\u003e Adecuado también para correr, gimnasio, tenis, y más.\u003c\/li\u003e\n        \u003cli\u003e\n\u003cstrong\u003eComodidad y Transpirabilidad:\u003c\/strong\u003e La microfibra estirable proporciona comodidad y buena ventilación.\u003c\/li\u003e\n      \u003c\/ul\u003e\n    \u003c\/div\u003e\n  \u003c\/div\u003e\n\u003c\/div\u003e\n","published_at":"2025-07-03T09:04:02-03:00","created_at":"2025-07-03T09:04:06-03:00","updated_at":"2026-06-12T15:10:32-03:00","vendor":"Vairo","product_type":"","tags":["Ropa Deportiva \u003e Man \u003e Shorts","untagged"],"variants":[{"id":48268923109581,"title":"s","option1":"s","option2":null,"option3":null,"sku":"215001001 0603","requires_shipping":true,"taxable":true,"featured_image":null,"available":false,"price":"43000.00","grams":180,"compare_at_price":"0.00","position":1,"product_id":9032069939405,"created_at":"2025-07-03T09:04:07-03:00","updated_at":"2026-06-12T15:10:32-03:00"},{"id":48268923142349,"title":"m","option1":"m","option2":null,"option3":null,"sku":"215001001 0604","requires_shipping":true,"taxable":true,"featured_image":null,"available":true,"price":"43000.00","grams":180,"compare_at_price":"0.00","position":2,"product_id":9032069939405,"created_at":"2025-07-03T09:04:07-03:00","updated_at":"2026-06-12T15:10:32-03:00"},{"id":48268923175117,"title":"l","option1":"l","option2":null,"option3":null,"sku":"215001001 0605","requires_shipping":true,"taxable":true,"featured_image":null,"available":true,"price":"43000.00","grams":180,"compare_at_price":"0.00","position":3,"product_id":9032069939405,"created_at":"2025-07-03T09:04:07-03:00","updated_at":"2026-06-12T15:10:32-03:00"},{"id":48268923207885,"title":"xl","option1":"xl","option2":null,"option3":null,"sku":"215001001 0606","requires_shipping":true,"taxable":true,"featured_image":null,"available":false,"price":"43000.00","grams":180,"compare_at_price":"0.00","position":4,"product_id":9032069939405,"created_at":"2025-07-03T09:04:07-03:00","updated_at":"2026-06-12T15:10:32-03:00"},{"id":48489230041293,"title":"xxl","option1":"xxl","option2":null,"option3":null,"sku":"215001001 0607","requires_shipping":true,"taxable":true,"featured_image":null,"available":true,"price":"43000.00","grams":180,"compare_at_price":"0.00","position":5,"product_id":9032069939405,"cr