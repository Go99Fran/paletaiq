:"\u003cdiv class=\"tabs-minimal\"\u003e\n\u003cinput checked id=\"tab1\" name=\"tabs\" type=\"radio\"\u003e \u003cinput id=\"tab2\" name=\"tabs\" type=\"radio\"\u003e \u003cinput id=\"tab3\" name=\"tabs\" type=\"radio\"\u003e\n\u003cdiv class=\"tab-labels\"\u003e\n\u003clabel for=\"tab1\"\u003eMI TALLE\u003c\/label\u003e \u003clabel for=\"tab2\"\u003eDESCRIPCIÓN\u003c\/label\u003e \u003clabel for=\"tab3\"\u003eTECNOLOGÍA\u003c\/label\u003e\n\u003c\/div\u003e\n\u003cdiv class=\"tab-content\"\u003e\n\u003c!-- TALLES --\u003e\n\u003cdiv id=\"content1\"\u003e\u003cbutton style=\"background: none; border: none; color: #000; font-size: 14px; text-decoration: underline; cursor: pointer;\"\u003e Ver Guía de Talles \u003c\/button\u003e\u003c\/div\u003e\n\u003c!-- DESCRIPCIÓN --\u003e\n\u003cdiv id=\"content2\"\u003e\n\u003cstrong\u003eLa Camiseta Vairo BK \u003c\/strong\u003eConfort es la elección definitiva para hombres que buscan un óptimo rendimiento deportivo sin sacrificar comodidad ni estilo. Confeccionada con una combinación de microfibra de poliéster y spandex, esta camiseta sublimada te brindará la experiencia definitiva durante tus entrenamientos.\u003c\/div\u003e\n\u003c!-- TECNOLOGÍA --\u003e\n\u003cdiv id=\"content3\"\u003e\n\u003cul\u003e\n\u003cli\u003e\n\u003cstrong\u003eSET POLYESTER:\u003c\/strong\u003e Fibra sintética liviana con resistencia al rasgado que absorbe menos humedad para una mejor higiene.\u003c\/li\u003e\n\u003cli\u003e\n\u003cstrong\u003eULTRA LIGHT:\u003c\/strong\u003e Tejido ultra liviano de alto rendimiento.\u003c\/li\u003e\n\u003cli\u003e\n\u003cstrong\u003eAIR TECH:\u003c\/strong\u003e Tejido diseñado para permitir el máximo de circulación de aire, reduciendo así el calor y la humedad.\u003c\/li\u003e\n\u003cli\u003e\n\u003cstrong\u003eSUBLIMATE:\u003c\/strong\u003e Diseño exclusivo, sublimado de alta calidad que preserva la intensidad de los colores.\u003c\/li\u003e\n\u003c\/ul\u003e\n\u003c\/div\u003e\n\u003c\/div\u003e\n\u003c\/div\u003e","published_at":"2025-07-03T09:03:02-03:00","created_at":"2025-07-03T09:03:06-03:00","updated_at":"2026-06-12T15:10:32-03:00","vendor":"Vairo","product_type":"","tags":["Hombre","Negro","Ropa Deportiva","Verde"],"variants":[{"id":48268920029389,"title":"s","option1":"s","option2":null,"option3":null,"sku":"227001016 1103","requires_shipping":true,"taxable":true,"featured_image":null,"available":true,"price":"41000.00","grams":180,"compare_at_price":"0.00","position":1,"product_id":9032069415117,"created_at":"2025-07-03T09:03:07-03:00","updated_at":"2026-06-12T15:10:32-03:00"},{"id":48268920062157,"title":"m","option1":"m","option2":null,"option3":null,"sku":"227001016 1104","requires_shipping":true,"taxable":true,"featured_image":null,"available":true,"price":"41000.00","grams":180,"compare_at_price":"0.00","position":2,"product_id":9032069415117,"created_at":"2025-07-03T09:03:07-03:00","updated_at":"2026-06-12T15:10:32-03:00"},{"id":48268920094925,"title":"l","option1":"l","option2":null,"option3":null,"sku":"227001016 1105","requires_shipping":true,"taxable":true,"featured_image":null,"available":true,"price":"41000.00","grams":180,"compare_at_price":"0.00","position":3,"product_id":9032069415117,"created_at":"2025-07-03T09:03:07-03:00","updated_at":"2026-06-12T15:10:32-03:00"},{"id":48268920127693,"title":"xl","option1":"xl","option2":null,"option3":null,"sku":"227001016 1106","requires_shipping":true,"taxable":true,"featured_image":null,"available":false,"price":"41000.00","grams":180,"compare_at_price":"0.00","position":4,"product_id":9032069415117,"created_at":"2025-07-03T09:03:07-03:00","updated_at":"2026-06-12T15:10:32-03:00"},{"id":48268920160461,"title":"xxl","option1":"xxl","option2":null,"option3":null,"sku":"227001016 1107","requires_shipping":true,"taxable":true,"featured_image":null,"available":true,"price":"41000.00","grams":180,"compare_at_price":"0.00","position":5,"product_id":9032069415117,"created_at":"2025-07-03T09:03:07-03:00","updated_at