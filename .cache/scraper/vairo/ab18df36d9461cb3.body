 un conjunto deportivo y elegante.\n        \u003c\/li\u003e\n        \u003cli\u003e\n          \u003cstrong\u003eFuncionalidad y versatilidad:\u003c\/strong\u003e\n          Es altamente funcional y te permitirá moverte con libertad. Ideal para distintas ocasiones y actividades.\n        \u003c\/li\u003e\n      \u003c\/ul\u003e\n    \u003c\/div\u003e\n  \u003c\/div\u003e\n\u003c\/div\u003e\n","published_at":"2025-07-03T09:03:36-03:00","created_at":"2025-07-03T09:03:41-03:00","updated_at":"2026-06-12T15:10:32-03:00","vendor":"Vairo","product_type":"","tags":["Invierno","Ropa Deportiva"],"variants":[{"id":48268922388685,"title":"l","option1":"l","option2":null,"option3":null,"sku":"228001001 0403","requires_shipping":true,"taxable":true,"featured_image":null,"available":true,"price":"132000.00","grams":180,"compare_at_price":"0.00","position":1,"product_id":9032069710029,"created_at":"2025-07-03T09:03:41-03:00","updated_at":"2026-06-12T15:10:32-03:00"},{"id":48268922421453,"title":"xl","option1":"xl","option2":null,"option3":null,"sku":"228001001 0503","requires_shipping":true,"taxable":true,"featured_image":null,"available":true,"price":"132000.00","grams":180,"compare_at_price":"0.00","position":2,"product_id":9032069710029,"created_at":"2025-07-03T09:03:41-03:00","updated_at":"2026-06-12T15:10:32-03:00"},{"id":48268922454221,"title":"s","option1":"s","option2":null,"option3":null,"sku":"228001001 0203","requires_shipping":true,"taxable":true,"featured_image":null,"available":false,"price":"132000.00","grams":180,"compare_at_price":"0.00","position":3,"product_id":9032069710029,"created_at":"2025-07-03T09:03:41-03:00","updated_at":"2026-06-12T15:10:32-03:00"},{"id":48268922519757,"title":"m","option1":"m","option2":null,"option3":null,"sku":"228001001 0303","requires_shipping":true,"taxable":true,"featured_image":null,"available":true,"price":"132000.00","grams":180,"compare_at_price":"0.00","position":4,"product_id":9032069710029,"created_at":"2025-07-03T09:03:41-