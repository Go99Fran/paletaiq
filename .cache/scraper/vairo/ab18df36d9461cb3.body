\"tabs\" type=\"radio\"\u003e\n  \u003cdiv class=\"tab-labels\"\u003e\n    \u003clabel for=\"tab1\"\u003eMI TALLE\u003c\/label\u003e\n    \u003clabel for=\"tab2\"\u003eDESCRIPCIÓN\u003c\/label\u003e\n  \u003c\/div\u003e\n  \u003cdiv class=\"tab-content\"\u003e\n\n    \u003c!-- MI TALLE --\u003e\n    \u003cdiv id=\"content1\"\u003e\n      \u003cbutton onclick=\"document.getElementById('sizeGuideModal').style.display='block'\" style=\"background:none; border:none; color:#000; font-size:14px; text-decoration:underline; cursor:pointer;\"\u003e\n        Ver Guía de Talles\n      \u003c\/button\u003e\n    \u003c\/div\u003e\n\n    \u003c!-- DESCRIPCIÓN --\u003e\n    \u003cdiv id=\"content2\"\u003e\n      \u003cul\u003e\n        \u003cli\u003e\n          \u003cstrong\u003eDiseño moderno con capucha y canguro:\u003c\/strong\u003e\n          El Hoodie Fog Lady presenta un diseño contemporáneo que incluye una capucha y un práctico bolsillo canguro en la parte frontal. Esta combinación de elementos le da un toque moderno y versátil, perfecto para el uso diario y para actividades deportivas.\n        \u003c\/li\u003e\n        \u003cli\u003e\n          \u003cstrong\u003eTejido rústico gamuzado:\u003c\/strong\u003e\n          El tejido rústico gamuzado utilizado en la confección del Hoodie Fog Lady proporciona una sensación suave al tacto y una apariencia elegante. Además, este material garantiza una durabilidad excepcional, asegurando que el buzo se mantenga en excelentes condiciones a lo largo del tiempo.\n        \u003c\/li\u003e\n        \u003cli\u003e\n          \u003cstrong\u003eBuzo de media estación:\u003c\/strong\u003e\n          Es perfecta para usar en días frescos y durante los cambios de clima. Proporciona la cantidad justa de abrigo sin ser demasiado pesado.\n        \u003c\/li\u003e\n        \u003cli\u003e\n          \u003cstrong\u003eCombinable con el Jogger Fog Lady:\u003c\/strong\u003e\n          Puedes combinarlo con el Jogger Fog Lady en el mismo color melange gris topo, formando un conjunto deportivo y elegante.\n        \u003c\/li\u003e\n        \u003cli\u003e\n          \u003cstrong\u003eFuncionalidad y versatilidad:\u003c\/strong\u003e\n          Es altamente funcional y te permitirá moverte con libertad. Ideal para distintas ocasiones y actividades.\n        \u003c\/li\u003e\n      \u003c\/ul\u003e\n    \u003c\/div\u003e\n  \u003c\/div\u003e\n\u003c\/div\u003e\n","published_at":"2025-07-03T09:03:30-03:00","created_at":"2025-07-03T09:03:35-03:00","updated_at":"2026-06-12T15:10:32-03:00","vendor":"Vairo","product_type":"","tags":["Invierno","Ropa Deportiva \u003e Woman"],"variants":[{"id":48268922257613,"title":"l","option1":"l","option2":null,"option3":null,"sku":"228001002 0403","requires_shipping":true,"taxable":true,"featured_image":null,"available":true,"price":"132000.00","grams":180,"compare_at_price":"0.00","position":1,"product_id":9032069677261,"created_at":"2025-07-03T09:03:35-03:00","updated_at":"2026-06-12T15:10:32-03:00"},{"id":48268922290381,"title":"xl","option1":"xl","option2":null,"option3":null,"sku":"228001002 0503","requires_shipping":true,"taxable":true,"featured_image":null,"available":false,"price":"132000.00","grams":180,"compare_at_price":"0.00","position":2,"product_id":9032069677261,"created_at":"2025-07-03T09:03:35-03:00","updated_at":"2026-06-12T15:10:32-03:00"},{"id":48268922323149,"title":"m","option1":"m","option2":null,"option3":null,"sku":"228001002 0303","requires_shipping":true,"taxable":true,"featured_image":null,"available":true,"price":"132000.00","grams":180,"compare_at_price":"0.00","position":3,"product_id":9032069677261,"created_at":"2025-07-03T09:03:35-03:00","updated_at":"2026-06-12T15:10:32-03:00"},{"id":48268922355917,"title":"s","option1":"s","option2":null,"option3":null,"sku":"228001002 0203","requires_shipping":true,"taxable":true,"featured_image":null,"available":true,"price":"132000.00","grams":180,"compare_at_price":"0.00","position":4,"product_id":9032069677261,"c