 adaptarse al cuerpo sin deformar la prenda. Cuenta con \u003c\/span\u003e\u003cem\u003ebolsillos laterales con cierre de seguridad y cuello alto con cierre frontal\u003c\/em\u003e\u003cspan\u003e que permite un ajuste total.\u003c\/span\u003e\n\u003c\/div\u003e\n\u003cdiv class=\"tabs-minimal\"\u003e\n\u003cspan\u003e\u003c\/span\u003e\u003cbr\u003e\n\u003c\/div\u003e\n\u003cdiv class=\"tabs-minimal\"\u003e\n\u003cinput checked id=\"tab1\" name=\"tabs\" type=\"radio\"\u003e \u003cinput id=\"tab2\" name=\"tabs\" type=\"radio\"\u003e\n\u003cdiv class=\"tab-labels\"\u003e\n\u003clabel for=\"tab1\"\u003eMI TALLE\u003c\/label\u003e \u003clabel for=\"tab2\"\u003eTECNOLOGÍA\u003c\/label\u003e\n\u003c\/div\u003e\n\u003cdiv class=\"tab-content\"\u003e\n\u003c!-- TALLES --\u003e\n\u003cdiv id=\"content1\"\u003e\n\u003cdiv style=\"margin-bottom: 8px;\"\u003e\n\n\u003c\/div\u003e\n \u003cbutton onclick=\"document.getElementById('sizeGuideModal').style.display='block'\" style=\"background:none; border:none; color:#000; font-size:14px; text-decoration:underline; cursor:pointer;\"\u003e\n        Ver Guía de Talles\n      \u003c\/button\u003e\n\u003c\/div\u003e\n\u003c!-- TECNOLOGÍA --\u003e\n\u003cdiv id=\"content2\"\u003e\n\u003cul\u003e\n\u003cli\u003e\n\u003cstrong\u003eSIDE POCKETS:\u003c\/strong\u003e Bolsillos laterales con cierre de seguridad.\u003c\/li\u003e\n\u003cli\u003e\n\u003cstrong\u003eFULL CLOSURE:\u003c\/strong\u003e Cuello alto con cierre frontal que permite un ajuste total.\u003c\/li\u003e\n\u003c\/ul\u003e\n\u003c\/div\u003e\n\u003c\/div\u003e\n\u003c\/div\u003e","published_at":"2025-07-03T09:05:16-03:00","created_at":"2025-07-03T09:05:18-03:00","updated_at":"2026-06-12T15:10:32-03:00","vendor":"Vairo","product_type":"","tags":["Invierno","Ropa Deportiva \u003e Woman"],"variants":[{"id":48268925272269,"title":"S","option1":"S","option2":null,"option3":null,"sku":"221001008 0303","requires_shipping":true,"taxable":true,"featured_image":null,"available":true,"pr