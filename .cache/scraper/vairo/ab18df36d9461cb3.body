g?v=1754318055","width":1080,"height":1080}],"options":[{"name":"Talle","position":1,"values":["s","m","l","xl"]}]},{"id":9104912384205,"title":"Remera One","handle":"remera-one","body_html":"\u003cdiv class=\"tabs-minimal\"\u003e\u003cspan\u003eLa camiseta ONE ofrece rendimiento sin concesiones para el jugador profesional de pádel. Con ajuste regular, tejidos premium y cortes respirables que mejoran la ventilación, garantiza frescura y confort gracias a su tratamiento antibacteriano. Ideal para destacarse dentro y fuera de la pista. 90% poliéster y 10% spandex. Negro y naranja..\u003c\/span\u003e\u003c\/div\u003e\n\u003cdiv class=\"tabs-minimal\"\u003e\u003cbr\u003e\u003c\/div\u003e\n\u003cdiv class=\"tabs-minimal\"\u003e\n\u003cinput type=\"radio\" name=\"tabs\" id=\"tab1\" checked\u003e \u003cinput type=\"radio\" name=\"tabs\" id=\"tab2\"\u003e \u003cinput type=\"radio\" name=\"tabs\" id=\"tab3\"\u003e\n\u003cdiv class=\"tab-labels\"\u003e\n\u003clabel for=\"tab1\"\u003eMI TALLE\u003c\/label\u003e \u003clabel for=\"tab2\"\u003eDESCRIPCIÓN\u003c\/label\u003e \u003clabel for=\"tab3\"\u003eTECNOLOGÍA\u003c\/label\u003e\n\u003c\/div\u003e\n\u003cdiv class=\"tab-content\"\u003e\n\u003c!-- TALLES --\u003e\n\u003cdiv id=\"content1\"\u003e\n\u003cdiv style=\"margin-bottom: 8px;\"\u003e\u003cbr\u003e\u003c\/div\u003e\n\u003cbutton style=\"background: none; border: none; color: #000; font-size: 14px; text-decoration: underline; cursor: pointer;\"\u003e Ver Guía de Talles \u003c\/button\u003e\n\u003c\/div\u003e\n\u003c!-- DESCRIPCIÓN --\u003e\n\u003cdiv id=\"content2\"\u003e\n\u003cp\u003e\u003cstrong\u003eRendimiento y Diseño:\u003c\/strong\u003e\u003cbr\u003eRendimiento sin concesiones. Diseñada para el jugador profesional de pádel, con ajuste regular y tejidos premium. Incorpora cortes respirables que optimizan la ventilación en cada punto y tratamiento antibacteriano para asegurar frescura y confort durante todo el juego. Ideal para destacarse dentro y fuera de la pista.\u003cbr\u003e\u003c\/p\u003e\n\u003cp\u003e\u003cstrong\u003eComposición:\u003c\/strong\u003e\u003cbr\u003ePoliéster 90% – Spandex 10%.\u003c\/p\u003e\n\u003cp\u003e\u003cstrong\u003eColores disponibles:\u003c\/strong\u003e\u003cbr\u003eNegro y naranja.\u003c\/p\u003e\n\u003c\/div\u003e\n\u003c!-- TECNOLOGÍA --\u003e\n\u003cdiv id=\"content3\"\u003e\n\u003cul\u003e\n\u003cli\u003e\u003cstrong\u003e\u003c\/strong\u003e\u003c\/li\u003e\n\u003c\/ul\u003e\n\u003cbr\u003e\n\u003cp\u003e \u003c\/p\u003e\n\u003c\/div\u003e\n\u003c\/div\u003e\n\u003c\/div\u003e","published_at":"2026-03-10T12:58:07-03:00","created_at":"2026-02-18T09:20:09-03:00","updated_at":"2026-06-12T15:10:32-03:00","vendor":"Vairo","product_type":"","tags":["Gris","Hombre","Ropa Deportiva"],"variants":[{"id":48536249237709,"title":"xl","option1":"xl","option2":null,"option3":null,"sku":"201001107  0513","requires_shipping":true,"taxable":true,"featured_image":null,"available":true,"price":"48000.00","grams":400,"compare_at_price":"0.00","position":1,"product_id":9104912384205,"created_at":"2026-02-18T09:20:09-03:00","updated_at":"2026-06-12T15:10:32-03:00"},{"id":48536249270477,"title":"l","option1":"l","option2":null,"option3":null,"sku":"201001107  0413","requires_shipping":true,"taxable":true,"featured_image":null,"available":true,"price":"48000.00","grams":400,"compare_at_price":"0.00","position":2,"product_id":9104912384205,"created_at":"2026-02-18T09:20:09-03:00","updated_at":"2026-06-12T15:10:32-03:00"},{"id":48536249303245,"title":"m","option1":"m","option2":null,"option3":null,"sku":"201001107  0313","requires_shipping":true,"taxable":true,"featured_image":null,"available":true,"price":"48000.00","grams":400,"compare_at_price":"0.00","position":3,"product_id":9104912384205,"created_at":"2026-02-18T09:20:09-03:00","updated_at":"2026-06-12T15:10:32-03:00"},{"id":48536249336013,"title":"s","option1":"s","option2":null,"option3":null,"sku":"201001107  0213","requires_shipping":true,"taxable":true,