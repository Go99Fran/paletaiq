080,"height":1080},{"id":55032816795853,"created_at":"2026-05-28T10:48:01-03:00","position":9,"updated_at":"2026-05-28T10:48:03-03:00","product_id":9032067449037,"variant_ids":[],"src":"https:\/\/cdn.shopify.com\/s\/files\/1\/0653\/4745\/3133\/files\/EVERLASTSPEED05.jpg?v=1779976083","width":1080,"height":1080}],"options":[{"name":"Title","position":1,"values":["Default Title"]}]},{"id":9032069611725,"title":"Falda con calza BK Confort","handle":"falda-con-calza-bk-confort","body_html":"\u003cp\u003e\u003cstrong\u003eLa Falda con calza BK Confort\u003c\/strong\u003e es perfecta para la práctica y el juego, ideal para pádel y otros deportes. Con dos recortes laterales y colores combinados en negro y cyan, ofrece estilo y funcionalidad. Está sublimada para mayor durabilidad y se combina perfectamente con la musculosa BK Confort y otras remeras de Vairo.\u003c\/p\u003e\n\u003cdiv class=\"tabs-minimal\"\u003e\n\u003cinput type=\"radio\" name=\"tabs\" id=\"tab1\" checked\u003e \u003cinput type=\"radio\" name=\"tabs\" id=\"tab2\"\u003e\n\u003cdiv class=\"tab-labels\"\u003e\n\u003clabel for=\"tab1\"\u003eMI TALLE\u003c\/label\u003e \u003clabel for=\"tab2\"\u003eTECNOLOGÍA\u003c\/label\u003e\n\u003c\/div\u003e\n\u003cdiv class=\"tab-content\"\u003e\n\u003c!-- TALLES --\u003e\n\u003cdiv id=\"content1\"\u003e\u003cbutton style=\"background: none; border: none; color: #000; font-size: 14px; text-decoration: underline; cursor: pointer;\"\u003e Ver Guía de Talles \u003c\/button\u003e\u003c\/div\u003e\n\u003c!-- TECNOLOGÍA --\u003e\n\u003cdiv id=\"content2\"\u003e\n\u003cul\u003e\n\u003cli\u003e\n\u003cstrong\u003eSPANDEX LYCRA:\u003c\/strong\u003e Fibras sintéticas con alta capacidad de elasticidad que permiten adaptarse sin deformar la prenda.\u003c\/li\u003e\n\u003cli\u003e\n\u003cstrong\u003eCONFORT:\u003c\/strong\u003e Tejido confortable muy elástico que aumenta el flujo de aire y la comodidad durante tus rodadas.\u003c\/li\u003e\n\u003cli\u003e\n\u003cstrong\u003eSUBLIMATE:\u003c\/strong\u003e Diseño exclusivo, sublimado de alta calidad que preserva la intensidad de los colores.\u003c\/li\u003e\n\u003c\/ul\u003e\n\u003c\/div\u003e\n\u003c\/div\u003e\n\u003c\/div\u003e","published_at":"2025-07-03T09:03:25-03:00","created_at":"2025-07-03T09:03:29-03:00","updated_at":"2026-06-12T15:10:32-03:00","vendor":"Vairo","product_type":"","tags":["Mujer","Negra","Ropa Deportiva \u003e Woman","Verde"],"variants":[{"id":48268920750285,"title":"m","option1":"m","option2":null,"option3":null,"sku":"213001005 2304","requires_shipping":true,"taxable":true,"featured_image":null,"available":true,"price":"43000.00","grams":180,"compare_at_price":"0.00","position":1,"product_id":9032069611725,"created_at":"2025-07-03T09:03:29-03:00","updated_at":"2026-06-12T15:10:32-03:00"},{"id":48268920783053,"title":"l","option1":"l","option2":null,"option3":null,"sku":"213001005 2305","requires_shipping":true,"taxable":true,"featured_image":null,"available":false,"price":"43000.00","grams":180,"compare_at_price":"0.00","position":2,"product_id":9032069611725,"created_at":"2025-07-03T09:03:29-03:00","updated_at":"2026-06-12T15:10:32-03:00"},{"id":48268920815821,"title":"xl","option1":"xl","option2":null,"option3":null,"sku":"213001005 2306","requires_shipping":true,"taxable":true,"featured_image":null,"available":true,"price":"43000.00","grams":180,"compare_at_price":"0.00","position":3,"product_id":9032069611725,"created_at":"2025-07-03T09:03:29-03:00","updated_at":"2026-06-12T15:10:32-03:00"},{"id":48268920848589,"title":"s","option1":"s","option2":null,"option3":null,"sku":"213001005 2303","requires_shipping":true,"taxable":true,"featured_image":null,"available":false,"price":"43000.00","grams":180,"compare_at_price":"0.00","position":4,"product_id":9032069611725,"created_at":"2025-07-03T09:03:29-03:00","updated_at":"2026-06-12T15:10:32-03:00"}],"images":[{"id":54373247975629,"created_at":"2025-08-04T12:40:50-03:00","position":1,"updated_at":"2025-08-04T12:40:52-03:00","product_id":9032069611725,"variant_ids":[],"src":"https:\/\/cdn.shopify.com\/s\/files\/1\/0653\/4745\/3133\/files\/bkconfort-frente.jpg?v=1754322052","width":1080,"height":1080},{"id":54373248008397,"created_at":"2025-08-04T12:40:50-03:00","position":2,"updated_at":"2025-08-04T12:40:52-03:00","product_id":9032069611725,"variant_ids":[],"src":"https:\/\/cdn.shopify.com\/s\/files\/1\/0653\/4745\/3133\/files\/bkconfort-dorso.jpg?v=1754322052","width":1080,"height":1080}],"options":[{"name":"Talle","position":1,"values":["m","l","xl","s"]}]},{"id":9032070463693,"title":"Falda Lady Team Blanco","handle":"falda-lady-team-blanco","body_html":"\u003cdiv class=\"tabs-minimal\"\u003e\n  \u003cspan\u003eLa \u003cstrong\u003eFalda Lady Team\u003c\/strong\u003e es una prenda diseñada para brindar comodidad y versatilidad durante la práctica o el juego.\u003c\/span\u003e\n\u003c\/div\u003e\n\n\u003cdiv class=\"tabs-minimal\"\u003e\n  \u003cinput type=\"radio\" name=\"tabs\" id=\"tab1\" checked\u003e\n  \u003cinput type=\"radio\" name=\"tabs\" id=\"tab2\"\u003e\n  \u003cinput type=\"radio\" name=\"tabs\" id=\"tab3\"\u003e\n  \u003cdiv class=\"tab-labels\"\u003e\n    \u003clabel for=\"tab1\"\u003eMI TALLE\u003c\/label\u003e\n    \u003clabel for=\"tab2\"\u003eDESCRIPCIÓN\u003c\/label\u003e\n    \u003clabel for=\"tab3\"\u003eTECNOLOGÍA\u003c\/label\u003e\n  \u003c\/div\u003e\n  \u003cdiv class=\"tab-content\"\u003e\n    \u003c!-- TALLES --\u003e\n    \u003cdiv id=\"content1\"\u003e\n      \u003cdiv style=\"margin-bottom:8px;\"\u003e\n    \n      \u003c\/div\u003e\n      \u003cbutton onclick=\"document.getElementById('sizeGuideModal').style.display='block'\" style=\"background:none; border:none; color:#000; font-size:14px; text-decoration:underline; cursor:pointer;\"\u003e\n        Ver Guía de Talles\n      \u003c\/button\u003e\n    \u003c\/div\u003e\n    \u003c!-- DESCRIPCIÓN --\u003e\n    \u003cdiv id=\"content2\"\u003e\n      \u003cp\u003e\u003cstrong\u003eFalda con calza integrada:\u003c\/strong\u003e\u003cbr\u003e\n      La Falda Lady Team cuenta con una calza integrada que brinda cobertura y comodidad adicional. Esta combinación de falda y calza permite moverse con libertad sin preocuparse por el ajuste o la exposición.\u003c\/p\u003e\n      \u003cp\u003e\u003cstrong\u003eRecorte lateral:\u003c\/strong\u003e\u003cbr\u003e\n      La falda presenta un recorte lateral que agrega un toque de estilo y dinamismo al diseño. Este detalle no solo es estético, sino que también mejora la movilidad al realizar movimientos rápidos y ágiles.\u003c\/p\u003e\n      \u003cp\u003e\u003cstrong\u003eIdeal para práctica o juego:\u003c\/strong\u003e\u003cbr\u003e\n      Esta falda con calza es perfecta para la práctica del padel como para diversos deportes, como tenis, voleibol y más. Brinda el equilibrio adecuado entre estilo y funcionalidad para rendir al máximo en la cancha.\u003c\/p\u003e\n      \u003cp\u003e\u003cstrong\u003eColor negro:\u003c\/strong\u003e\u003cbr\u003e\n      La Falda Lady Team está disponible en un elegante color negro que combina fácilmente con otras prendas deportivas y permite crear conjuntos armoniosos.\u003c\/p\u003e\n      \u003cp\u003e\u003cstrong\u003eConfección de alta calidad:\u003c\/strong\u003e\u003cbr\u003e\n      Fabricada con materiales de calidad, la falda con calza ofrece durabilidad y resistencia, manteniendo su forma y color incluso después de un uso frecuente y lavados repetidos.\u003c\/p\u003e\n      \u003cp\u003e\u003cstrong\u003eDiseño femenino y elegante:\u003c\/strong\u003e\u003cbr\u003e\n      La Falda Lady Team tiene un diseño femenino y elegante que realza la figura y brinda una imagen impecable en la cancha o en cualquier actividad deportiva.\u003c\/p\u003e\n    \u003c\/div\u003e\n    \u003c!-- TECNOLOGÍA --\u003e\n    \u003cdiv id=\"content3\"\u003e\n      \u003cul\u003e\n        \u003cli\u003e\n          \u003cstrong\u003eSPANDEX LYCRA:\u003c\/strong\u003e Fibras sintéticas con alta capacidad de elasticidad que permiten adaptarse sin deformar la prenda.\n        \u003c\/li\u003e\n        \u003cli\u003e\n          \u003cstrong\u003eCONFORT:\u003c\/strong\u003e Tejido confortable muy elástico que aumenta el flujo de aire y la comodidad durante tus rodadas.\n        \u003c\/li\u003e\n      \u003c\/ul\u003e\n      \u003cbr\u003e\n     \n\u003c\/div\u003e\n\u003c\/div\u003e\n\u003c\/div\u003e","published_at":"2026-05-04T16:06:21-03:00","created_at":"2025-07-03T09:05:09-03:00","updated_at":"2026-06-12T15:10:32-03:00","vendor":"Vairo","product_type":"","tags":["Mujer","Ropa Deportiva \u003e Woman"],"variants":[{"id":48268925010125,"title":"s","option1":"s","option2":null,"option3":null,"sku":"201091021 0201","requires_shipping":true,"taxable":true,"featured_image":null,"available":false,"price":"43000.00","grams":180,"compare_at_price":"0.00","position":1,"product_id":9032070463693,"created_at":"2025-07-03T09:05:09-03:00","updated_at":"2026-06-12T15:10:32-03:00"},{"id":48268925042893,"title":"m","option1":"m","option2":null,"option3":null,"sku":"201091021 0301","requires_shipping":true,"taxable":true,"featured_image":null,"available":false,"price":"43000.00","grams":180,"compare_at_price":"0.00","position":2,"product_id":9032070463693,"created_at":"2025-07-03T09:05:09-03:00","updated_at":"2026-06-12T15:10:32-03:00"},{"id":48268925075661,"title":"l","option1":"l","option2":null,"option3":null,"sku":"201091021 0401","requires_shipping":true,"taxable":true,"featured_image":null,"available":true,"price":"43000.00","grams":180,"compare_at_price":"0.00","position":3,"product_id":9032070463693,"created_at":"2025-07-03T09:05:09-03:00","updated_at":"2026-06-12T15:10:32-03:00"},{"id":48268925108429,"title":"xl","option1":"xl","option2":null,"option3":null,"sku":"201091021 0501","requires_shipping":true,"taxable":true,"featured_image":null,"available":false,"price":"43000.00","grams":180,"compare_at_price":"0.00","position":4,"product_id":9032070463693,"created_at":"2025-07-03T09:0