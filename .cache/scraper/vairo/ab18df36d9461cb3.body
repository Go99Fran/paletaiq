l","xxl"]}]},{"id":9032069775565,"title":"Jogger Fog Lady","handle":"jogger-fog-lady","body_html":"\u003cp\u003e\u003cstrong\u003eEl Jogger Fog Lady\u003c\/strong\u003e es un pantalón deportivo de mujer diseñado para ofrecer la combinación perfecta de estilo y comodidad al jugar al pádel. Con un elegante color Melange gris topo, este jogger destaca en la cancha y en cualquier actividad casual fuera de ella. Además, es altamente versátil y se puede combinar fácilmente con el Hoodie Fog Lady para crear un conjunto completo y funcional.\u003c\/p\u003e\n\n\u003cdiv class=\"tabs-minimal\"\u003e\n  \u003cinput checked id=\"tab1\" name=\"tabs\" type=\"radio\"\u003e\n  \u003cinput id=\"tab2\" name=\"tabs\" type=\"radio\"\u003e\n  \u003cdiv class=\"tab-labels\"\u003e\n    \u003clabel for=\"tab1\"\u003eMI TALLE\u003c\/label\u003e\n    \u003clabel for=\"tab2\"\u003eDESCRIPCIÓN\u003c\/label\u003e\n  \u003c\/div\u003e\n  \u003cdiv class=\"tab-content\"\u003e\n    \u003c!-- MI TALLE --\u003e\n    \u003cdiv id=\"content1\"\u003e\n      \u003cbutton onclick=\"document.getElementById('sizeGuideModal').style.display='block'\" style=\"background:none; border:none; color:#000; font-size:14px; text-decoration:underline; cursor:pointer;\"\u003e\n        Ver Guía de Talles\n      \u003c\/button\u003e\n    \u003c\/div\u003e\n    \u003c!-- DESCRIPCIÓN --\u003e\n    \u003cdiv id=\"content2\"\u003e\n      \u003cul\u003e\n        \u003cli\u003e\n\u003cstrong\u003eEstilo y elegancia:\u003c\/strong\u003e Diseño moderno y sofisticado, con color Melange gris topo, versátil para cualquier ocasión.\u003c\/li\u003e\n        \u003cli\u003e\n\u003cstrong\u003eComodidad y libertad de movimiento:\u003c\/strong\u003e Ajuste ceñido pero cómodo y tejido rústico gamuzado para máxima movilidad en la pista de pádel.\u003c\/li\u003e\n        \u003cli\u003e\n\u003cstrong\u003eTejido rústico gamuzado:\u003c\/strong\u003e Aporta durabilidad y resistencia, asegurando que el jogger se mantenga en óptimas condiciones.\u003c\/li\u003e\n        \u003cli\u003e\n\u003cstrong\u003ePantalón de media estación:\u003c\/strong\u003e Ideal para días frescos y temperaturas cambiantes.\u003c\/li\u003e\n        \u003cli\u003e\n\u003cstrong\u003eCombina con el Hoodie Fog Lady:\u003c\/strong\u003e Prendas diseñadas para complementarse y brindar un look impecable en la pista y fuera de ella.\u003c\/li\u003e\n      \u003c\/ul\u003e\n    \u003c\/div\u003e\n  \u003c\/div\u003e\n\u003c\/div\u003e\n","published_at":"2025-07-03T09:03:42-03:00","created_at":"2025-07-03T09:03:47-03:00","updated_at":"2026-06-12T15:10:32-03:00","vendor":"Vairo","product_type":"","tags":["Invierno","Ropa Deportiva \u003e Woman"],"variants":[{"id":48268922552525,"title":"l","option1":"l","option2":null,"option3":null,"sku":"228001011 0403","requires_shipping":true,"taxable":true,"featured_image":null,"available":true,"price":"89000.00","grams":180,"compare_at_price":"0.00","position":1,"product_id":9032069775565,"created_at":"2025-07-03T09:03:48-03:00","updated_at":"2026-06-12T15:10:32-03:00"},{"id":48268922585293,"title":"xl","option1":"xl","option2":null,"option3":null,"sku":"228001011 0503","requires_shipping":true,"taxable":true,"featured_image":null,"available":true,"price":"89000.00","grams":180,"compare_at_price":"0.00","position":2,"product_id":9032069775565,"created_at":"2025-07-03T09:03:48-03:00","updated_at":"2026-06-12T15:10:32-03:00"},{"id":48268922618061,"title":"s","option1":"s","option2":null,"option3":null,"sku":"228001011 0203","requires_shipping":true,"taxable":true,"featured_image":null,"available":true,"price":"89000.00","grams":180,"compare_at_price":"0.00","position":3,"product_id":9032069775565,"created_at":"2025-07-03T09:03:48-03:00","updated_at":"2026-06-12T15:10:32-03:00"},{"id":48268922650829,"title":"m","option1":"m","option2":null,"option3":null,"sku":"228001011 0303","requires_shipping":true,"taxable":true,"featured_image":null,"available":true,"price":"89000.00","grams":180,"compare_at_price":"0.00","position":4,"product_id":9032069775565,"created_at":"2025-07-03T09:03:48-03:00","updated_at":"2026-06-12T15:10:32-03:00"},{"id":48489230205133,"title":"XXL","option1":"XXL","option2":null,"option3":null,"sku":"228001011 0603","requires_shipping":true,"taxable":true,"featured_image":null,"available":true,"price":"89000.00","grams":180,"compare_at_price":"0.00","position":5,"product_id":9032069775565,"created_at":"2025-11-20T09:23:21-03:00","updated_at":"2026-06-12T15:10:32-03:00"}],"images":[{"id":54373170872525,"created_at":"2025-08-04T11:59:01-03:00","position":1,"updated_at":"2025-08-04T11:59:17-03:00","product_id":9032069775565,"variant_ids":[],"src":"https:\/\/cdn.shopify.com\/s\/files\/1\/0653\/4745\/3133\/files\/JoggerFogLady-Frente.jpg?v=1754319557","width":1080,"height":1080},{"id":54373170839757,"created_at":"2025-08-04T11:59:01-03:00","position":2,"updated_at":"2025-08-04T11:59:17-03:00","product_id":9032069775565,"variant_ids":[],"src":"https:\/\/cdn.shopify.com\/s\/files\/1\/0653\/4745\/3133\/files\/JoggerFogLady-Espalda.jpg?v=1754319557","width":1080,"height":1080},{"id":54373170905293,"created_at":"2025-08-04T11:59:01-03:00","position":3,"updated_at":"2025-08-04T11:59:03-03:00","product_id":9032069775565,"variant_ids":[],"src":"https:\/\/cdn.shopify.com\/s\/files\/1\/0653\/4745\/3133\/files\/JoggerFogLady-Perfil.jpg?v=1754319543","width":1080,"height":1080}],"options":[{"name":"Talle","position":1,"values":["l","xl","s","m","XXL"]}]},{"id":9032069808333,"title":"Jogger Fog Man","handle":"jogger-fog-man","body_html":"\u003cp\u003e\u003cstrong\u003e¿Estás buscando el pantalón deportivo perfecto para la media estación?\u003c\/strong\u003e No busques más, porque el Vairo Jogger Fog Man es la elección ideal para combinar estilo y comodidad en una sola prenda. Diseñado especialmente para hombres activos, este pantalón deportivo ofrece un ajuste óptimo y está confeccionado con tejido rústico gamuzado de alta calidad.\u003c\/p\u003e\n\n\u003cdiv class=\"tabs-minimal\"\u003e\n  \u003cinput checked id=\"tab1\" name=\"tabs\" type=\"radio\"\u003e\n  \u003cinput id=\"tab2\" name=\"tabs\" type=\"radio\"\u003e\n  \u003cdiv class=\"tab-labels\"\u003e\n    \u003clabel for=\"tab1\"\u003eMI TALLE\u003c\/label\u003e\n    \u003clabel for=\"tab2\"\u003eDESCRIPCIÓN\u003c\/label\u003e\n  \u003c\/div\u003e\n  \u003cdiv class=\"tab-content\"\u003e\n    \u003c!-- TALLES --\u003e\n    \u003cdiv id=\"content1\"\u003e\n      \n      \u003cbutton onclick=\"document.getElementById('sizeGuideModal').style.display='block'\" style=\"background:none; border:none; color:#000; font-size:14px; text-decoration:underline; cursor:pointer;\"\u003e\n        Ver Guía de Talles\n      \u003c\/button\u003e\n    \u003c\/div\u003e\n    \u003c!-- DESCRIPCIÓN --\u003e\n    \u003cdiv id=\"content2\"\u003e\n      \u003cul\u003e\n        \u003cli\u003e\n\u003cstrong\u003eTejido rústico gamuzado:\u003c\/strong\u003e El Vairo Jogger Fog Man destaca por su tejido de gamuza rústica, que no solo le da un toque de elegancia, sino que también proporciona una textura suave y cómoda al tacto.\u003c\/li\u003e\n        \u003cli\u003e\n\u003cstrong\u003eMedia estación perfecta:\u003c\/strong\u003e Con su diseño pensado para la media estación, este pantalón te ofrece el equilibrio perfecto entre transpirabilidad y calidez. Ideal para esos días cambiantes donde necesitas estar preparado para cualquier clima.\u003c\/li\u003e\n        \u003cli\u003e\n\u003cstrong\u003eEstilo versátil:\u003c\/strong\u003e Diseño moderno y contemporáneo, adecuado tanto para actividades deportivas como para uso diario.\u003c\/li\u003e\n        \u003cli\u003e\n\u003cstrong\u003eAjuste cómodo:\u003c\/strong\u003e Cintura elástica y corte ajustado que aseguran libertad de movimiento.\u003c\/li\u003e\n        \u003cli\u003e\n\u003cstrong\u003eDurabilidad y resistencia:\u003c\/strong\u003e Tejido de alta calidad diseñado para soportar el desgaste diario.\u003c\/li\u003e\n      \u003c\/ul\u003e\n    \u003c\/div\u003e\n  \u003c\/div\u003e\n\u003c\/div\u003e\n","published_at":"2025-07-03T09:03:48-03:00","created_at":"2025-07-03T09:03:52-03:00","updated_at":"2026-06-12T15:10:32-03:00","vendor":"Vairo","product_type":"","tags":["Ropa Deportiva","untagged"],"variants":[{"id":48268922683597,"title":"l","option1":"l","option2":null,"option3":null,"sku":"228001010 0403","requires_shipping":true,"taxable":true,"featured_image":null,"available":true,"price":"80000.00","grams":180,"compare_at_price":"0.00","position":1,"product_id":9032069808333,"created_at":"2025-07-03T09:03:52-03:00","updated_at":"2026-06-12T15:10:32-03:00"},{"id":48268922716365,"title":"xl","option1":"xl","option2":null,"option3":null,"sku":"228001010 0503","requires_shipping":true,"taxable":true,"featured_image":null,"available":true,"price":"80000.00","grams":180,"compare_at_price":"0.00","position":2,"product_id":9032069808333,"created_at":"2025-07-03T09:03:52-03:00","updated_at":"2026-06-12T15:10:32-03:00"},{"id":48268922749133,"title":"s","option1":"s","option2":null,"option3":null,"sku":"228001010 0203","requires_shipping":true,"taxable":true,"featured_image":null,"available":true,"price":"80000.00","grams":180,"compare_at_price":"0.00","position":3,"product_id":9032069808333,"created_at":"2025-07-03T09:03:52-03:00","updated_at":"2026-06-12T15:10:32-03:00"},{"id":48268922781901,"title":"m","option1":"m","option2":null,"option3":null,"sku":"228001010 0303","requires_shipping":true,"taxable":true,"featured_image":null,"available":true,"price":"80000.00","grams":180,"compare_at_price":"0.00","position":4,"product_id":9032069808333,"created_at":"2025-07-03T09:03:52-03:00","updated_at":"2026-06-12T15:10:32-03:00"},{"id":48489230532813,"title":"XXL","option1":"XXL","option2":null,"option3":null,"sku":"228001010 0603","requires_shipping":true,"taxable":true,"featured_image":null,"available":true,"price":"80000.00","grams":180,"compare_at_price":"0.00","position":5,"product_id":9032069808333,"created_