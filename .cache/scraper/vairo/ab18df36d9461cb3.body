ES --\u003e\n\u003cdiv id=\"content1\"\u003e\u003cbutton style=\"background: none; border: none; color: #000; font-size: 14px; text-decoration: underline; cursor: pointer;\"\u003e Ver Guía de Talles \u003c\/button\u003e\u003c\/div\u003e\n\u003c!-- TECNOLOGÍA --\u003e\n\u003cdiv id=\"content2\"\u003e\n\u003cul\u003e\n\u003cli\u003e\n\u003cstrong\u003eSET POLYESTER:\u003c\/strong\u003e Fibra sintética liviana con resistencia al rasgado que absorbe menos humedad para una mejor higiene.\u003c\/li\u003e\n\u003cli\u003e\n\u003cstrong\u003eULTRA LIGHT:\u003c\/strong\u003e Tejido ultra liviano de alto rendimiento.\u003c\/li\u003e\n\u003cli\u003e\n\u003cstrong\u003eAIR TECH:\u003c\/strong\u003e Tejido diseñado para permitir el máximo de circulación de aire, reduciendo así el calor y la humedad.\u003cbr\u003e\n\u003c\/li\u003e\n\u003c\/ul\u003e\n\u003c\/div\u003e\n\u003c\/div\u003e\n\u003c\/div\u003e","published_at":"2026-03-10T15:07:23-03:00","created_at":"2026-03-10T09:46:22-03:00","updated_at":"2026-06-12T15:10:32-03:00","vendor":"Vairo","product_type":"Indumentaria","tags":["Hombre","Ropa Deportiva","Unisex","Verde"],"variants":[{"id":48541455777997,"title":"xxl","option1":"xxl","option2":null,"option3":null,"sku":"201001105  0603","requires_shipping":true,"taxable":true,"featured_image":null,"available":true,"price":"38000.00","grams":400,"compare_at_price":"0.00","position":1,"product_id":9106547900621,"created_at":"2026-03-10T09:46:23-03:00","updated_at":"2026-06-12T15:10:32-03:00"},{"id":48541455810765,"title":"s","option1":"s","option2":null,"option3":null,"sku":"201001105  0203","requires_shipping":true,"taxable":true,"featured_image":null,"available":true,"price":"38000.00","grams":400,"compare_at_price":"0.00","position":5,"product_id":9106547900621,"created_at":"2026-03-10T09:46:23-03:00","updated_at":"2026-06-12T15:10:32-03:00"},{"id":48541455843533,"title":"m","option1":"m","option2":null,"option3":null,"sku":"201001105  0303","requires_shipping":true,"taxable":true,"featured_image":null,"available":true,"price":"38000.00","grams":400,"compare_at_price":"0.00","position":9,"product_id":9106547900621,"created_at":"2026-03-10T09:46:23-03:00","updated_at":"2026-06-12T15:10:32-03:00"},{"id":48541455876301,"title":"l","option1":"l","option2":null,"option3":null,"sku":"201001105  0403","requires_shipping":true,"taxable":true,"featured_image":null,"available":true,"price":"38000.00","grams":400,"compare_at_price":"0.00","position":13,"product_id":9106547900621,"created_at":"2026-03-10T09:46:23-03:00","updated_at":"2026-06-12T15:10:32-03:00"},{"id":48541455909069,"title":"xl","option1":"xl","option2":null,"option3":null,"sku":"201001105  0503","requires_shipping":true,"taxable":true,"featured_image":null,"available":true,"price":"38000.00","grams":400,"compare_at_price":"0.00","position":17,"product_id":9106547900621,"created_at":"2026-03-10T09:46:23-03:00","updated_at":"2026-06-12T15:10:32-03:00"}],"images":[{"id":54853140906189,"created_at":"2026-03-10T09:46:47-03:00","position":1,"updated_at":"2026-03-10T09:46:49-03:00","product_id":9106547900621,"variant_ids":[],"src":"https:\/\/cdn.shopify.com\/s\/files\/1\/0653\/4745\/3133\/files\/REMERACOMPANYIMPORTADA-VERDEFRENTE_9e487d90-9d43-4d97-ab46-735edb8d5ca2.png?v=1773146809","width":1080,"height":1080},{"id":54853140938957,"created_at":"2026-03-10T09:46:47-03:00","position":2,"updated_at":"2026-03-10T09:46:49-03:00","product_id":9106547900621,"variant_ids":[],"src":"https:\/\/cdn.shopify.com\/s\/files\/1\/0653\/4745\/3133\/files\/REMERACOMPANYIMPORTADA-VERDEDORSO_8c5894f6-6273-4fcd-ba83-c42e205c8d3a.png?v=1773146809","width":1080,"height":1080}],"options":[{"name":"Talle","position":1,"values":["xxl","s","m","l","xl"]}]},{"id":9032069873869,"title":"Remera Fly Azul","handle":"remera-fly-azul","body_html":"\u003cdiv class=\"tabs-minimal\"\u003e\n\u003cspan\u003eSi buscas una remera deportiva que se destaque por su diseño sublimado, liviandad y frescura, la \u003c\/span\u003e\u003cstrong\u003eRemera Vairo Fly\u003c\/strong\u003e\u003cspan\u003e es la elección perfecta. Diseñada especialmente para deportistas exigentes, esta prenda combina estilo y rendimiento para ofrecer una experiencia única durante tus actividades físicas.\u003c\/span\u003e\n\u003c\/div\u003e\n\u003cdiv class=\"tabs-minimal\"\u003e\u003cbr\u003e\u003c\/div\u003e\n\u003cdiv class=\"tabs-minimal\"\u003e\n\u003cinput checked id=\"tab1\" name=\"tabs\" type=\"radio\"\u003e \u003cinput id=\"tab2\" name=\"tabs\" type=\"radio\"\u003e \u003cinput id=\"tab3\" name=\"tabs\" type=\"radio\"\u003e\n\u003cdiv class=\"tab-labels\"\u003e\n\u003clabel for=\"tab1\"\u003eMI TALLE\u003c\/label\u003e \u003clabel for=\"tab2\"\u003eDESCRIPCIÓN\u003c\/label\u003e \u003clabel for=\"tab3\"\u003eTECNOLOGÍA\u003c\/label\u003e\n\u003c\/div\u003e\n\u003cdiv class=\"tab-content\"\u003e\n\u003c!-- TALLES --\u003e\n\u003cdiv id=\"content1\"\u003e\n\u003cdiv style=\"margin-bottom: 8px;\"\u003e\n\n\u003c\/div\u003e\n \u003cbutton onclick=\"document.getElementById('sizeGuideModal').style.display='block'\" style=\"background:none; border:none; color:#000; font-size:14px; text-decoration:underline; cursor:pointer;\"\u003e\n        Ver Guía de Talles\n      \u003c\/button\u003e\n\u003c\/div\u003e\n\u003c!-- DESCRIPCIÓN --\u003e\n\u003cdiv id=\"content2\"\u003e\n\u003cp\u003e\u003cstrong\u003eDiseño Sublimado:\u003c\/strong\u003e\u003cbr\u003eLa remera Fly presenta un diseño sublimado que no solo aporta un toque de modernidad, sino que también garantiza que los colores y patrones se mantengan vivos y vibrantes lavado tras lavado. ¡Destaca entre la multitud con esta remera de diseño llamativo!\u003c\/p\u003e\n\u003cp\u003e\u003cstrong\u003eLiviandad y Frescura:\u003c\/strong\u003e\u003cbr\u003eGracias a su confección con materiales de alta calidad, la Remera Vairo Fly se caracteriza por su ligereza y su capacidad para mantener una sensación fresca incluso en los momentos más intensos de tu entrenamiento.\u003c\/p\u003e\n\u003cp\u003e\u003cstrong\u003eTecnología Dry Release:\u003c\/strong\u003e\u003cbr\u003eLa innovadora tecnología Dry Release permite una óptima aireación al cuerpo del deportista, ayudando a mantener la piel seca y fresca durante todo el tiempo de uso. Di adiós a la incomodidad del sudor excesivo y disfruta de una mayor comodidad en cada movimiento.\u003c\/p\u003e\n\u003cp\u003e\u003cstrong\u003ePerfect Fit (Calce Perfecto):\u003c\/strong\u003e\u003cbr\u003eNada es más importante que la comodidad al realizar actividades deportivas. La Remera Vairo Fly ha sido diseñada con un calce Perfect Fit, lo que significa que se ajusta de forma óptima a tu cuerpo, brindando una sensación de ligereza y libertad de movimiento inigualable.\u003c\/p\u003e\n\u003c\/div\u003e\n\u003c!-- TECNOLOGÍA --\u003e\n\u003cdiv id=\"content3\"\u003e\n\u003cul\u003e\n\u003cli\u003e\n\u003cstrong\u003eULTRA LIGHT:\u003c\/strong\u003e Tejido ultra liviano de alto rendimiento\u003c\/li\u003e\n\u003cli\u003e\n\u003cstrong\u003eSUBLIMATE:\u003c\/strong\u003e Diseño exclusivo, sublimado de alta calidad que preserva la intensidad de los colores.\u003c\/li\u003e\n\u003cli\u003e\n\u003cstrong\u003eDRY RELEASE:\u003c\/strong\u003e Tejido diseñado para permitir el máximo de circulación de aire, reduciendo así el calor y humedad.\u003c\/li\u003e\n\u003c\/ul\u003e\n\u003cbr\u003e\n\u003cp\u003e \u003c\/p\u003e\n\u003c\/div\u003e\n\u003c\/div\u003e\n\u003c\/div\u003e","published_at":"2026-05-04T16:21:32-03:00","created_at":"2025-07-03T09:04:00-03:00","updated_at":"2026-06-12T15:10:32-03:00","vendor":"Vairo","product_type":"","tags":["Ropa Deportiva","untagged"],"variants":[{"id":48268922945741,"title":"xl","option1":"xl","option2":null,"option3":null,"sku":"227001020 3406","requires_shipping":true,"taxable":true,"featured_image":null,"available":false,"price":"49000.00","grams":400,"compare_at_price":"0.00","position":1,"product_id":9032069873869,"created_at":"2025-07-03T09:04:01-03:00","updated_at":"2