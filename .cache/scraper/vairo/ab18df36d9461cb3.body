i\u003e\n\u003cstrong\u003eMontura ergonómica:\u003c\/strong\u003e\u003cspan\u003e \u003c\/span\u003eAjuste óptimo y cómodo para largas jornadas.\u003c\/li\u003e\n\u003cli\u003e\n\u003cstrong\u003eVentilación superior:\u003c\/strong\u003e\u003cspan\u003e \u003c\/span\u003eEvita el empañamiento y mejora el flujo de aire.\u003cbr\u003e\n\u003c\/li\u003e\n\u003c\/ul\u003e\n\u003c\/div\u003e\n\u003c\/div\u003e\n\u003c\/div\u003e","published_at":"2025-12-04T14:54:00-03:00","created_at":"2025-11-13T12:08:11-03:00","updated_at":"2026-06-12T15:10:32-03:00","vendor":"Vairo Padel","product_type":"Accesorios","tags":[],"variants":[{"id":48483932963021,"title":"Verde","option1":"Verde","option2":null,"option3":null,"sku":"201101161","requires_shipping":true,"taxable":true,"featured_image":{"id":54632786624717,"product_id":9090215510221,"position":16,"created_at":"2025-11-13T12:10:18-03:00","updated_at":"2025-11-13T17:22:25-03:00","alt":null,"width":1080,"height":1080,"src":"https:\/\/cdn.shopify.com\/s\/files\/1\/0653\/4745\/3133\/files\/download_9529b687-0567-4695-8772-40097d5c6540.webp?v=1763065345","variant_ids":[48483932963021]},"available":true,"price":"143000.00","grams":0,"compare_at_price":"0.00","position":1,"product_id":9090215510221,"created_at":"2025-11-13T12:08:11-03:00","updated_at":"2026-06-12T15:10:32-03:00"},{"id":48483990339789,"title":"Azul","option1":"Azul","option2":null,"option3":null,"sku":"201101164","requires_shipping":true,"taxable":true,"featured_image":null,"available":true,"price":"143000.00","grams":0,"compare_at_price":"0.00","position":2,"product_id":9090215510221,"created_at":"2025-11-13T17:30:22-03:00","updated_at":"2026-06-12T15:10:32-03:00"}],"images":[{"id":54632786657485,"created_at":"2025-11-13T12:10:18-03:00","position":1,"updated_at":"2025-11-13T12:11:50-03:00","product_id":9090215510221,"variant_ids":[],"src":"https:\/\/cdn.shopify.com\/s\/files\/1\/0653\/4745\/3133\/files\/download_4cac1e82-ec95-43a7-ae05-5eb7295efaa5.webp?v=1763046710