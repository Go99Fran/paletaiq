3:00","position":8,"updated_at":"2026-05-28T11:08:44-03:00","product_id":9032067711181,"variant_ids":[],"src":"https:\/\/cdn.shopify.com\/s\/files\/1\/0653\/4745\/3133\/files\/GRAPHENOCLASSICCONFORT07.jpg?v=1779977324","width":1080,"height":1080},{"id":55032826134733,"created_at":"2026-05-28T11:08:42-03:00","position":9,"updated_at":"2026-05-28T11:08:44-03:00","product_id":9032067711181,"variant_ids":[],"src":"https:\/\/cdn.shopify.com\/s\/files\/1\/0653\/4745\/3133\/files\/GRAPHENOCLASSICCONFORT06.jpg?v=1779977324","width":1080,"height":1080},{"id":55032826167501,"created_at":"2026-05-28T11:08:42-03:00","position":10,"updated_at":"2026-05-28T11:08:44-03:00","product_id":9032067711181,"variant_ids":[],"src":"https:\/\/cdn.shopify.com\/s\/files\/1\/0653\/4745\/3133\/files\/GRAPHENOCLASSICCONFORT05.jpg?v=1779977324","width":1080,"height":1080}],"options":[{"name":"Title","position":1,"values":["Default Title"]}]},{"id":9032067678413,"title":"Grapheno Speed Classic 9.1","handle":"grapheno-speed-classic-9-1","body_html":"\u003cp\u003e\u003cstrong\u003eIncluye:\u003c\/strong\u003e Funda de tela con correas para usar como mochila.\u003c\/p\u003e\n\u003cp\u003e\u003cstrong\u003eIdeal para un juego de control, la Vairo Grapheno Speed es una pala con formato gota con balance medio para jugadores avanzados y profesionales.\u003c\/strong\u003e\u003c\/p\u003e\n\u003cdiv class=\"highlight-box\"\u003e\n\u003cstrong\u003eNivel de Juego:\u003c\/strong\u003e Avanzado \/ Competición   |   \u003cstrong\u003eTipo de Juego:\u003c\/strong\u003e Control + Potencia\u003c\/div\u003e\n\u003cdiv class=\"tabs-minimal\"\u003e\n\u003cinput checked id=\"tab1\" name=\"tabs\" type=\"radio\"\u003e \u003cinput id=\"tab2\" name=\"tabs\" type=\"radio\"\u003e \u003cinput id=\"tab3\" name=\"tabs\" type=\"radio\"\u003e\n\u003cdiv class=\"tab-labels\"\u003e\n\u003clabel for=\"tab1\"\u003eCARACTERÍSTICAS\u003c\/label\u003e \u003clabel for=\"tab2\"\u003eDESCRIPCIÓN\u003c\/label\u003e \u003clabel for=\"tab3\"\u003eTECNOLOGÍA\u003c\/label\u003e\n\u003c\/div\u003e\n\u003cdiv class=\"tab-content\"\u003e\n\u003c!-- CARACTERÍSTICAS --\u003e\n\u003cdiv id=\"content1\"\u003e\n\u003cdiv class=\"caracteristicas-grid\"\u003e\n\u003cdiv\u003e\n\u003ctable\u003e\n\u003ctbody\u003e\n\u003ctr\u003e\n\u003ctd\u003eFORMA:\u003c\/td\u003e\n\u003ctd\u003eGota\u003c\/td\u003e\n\u003c\/tr\u003e\n\u003ctr\u003e\n\u003ctd\u003eBALANCE:\u003c\/td\u003e\n\u003ctd\u003eMedio\u003c\/td\u003e\n\u003c\/tr\u003e\n\u003ctr\u003e\n\u003ctd\u003eMARCO:\u003c\/td\u003e\n\u003ctd\u003eCarbono\u003c\/td\u003e\n\u003c\/tr\u003e\n\u003ctr\u003e\n\u003ctd\u003eNÚCLEO:\u003c\/td\u003e\n\u003ctd\u003eEVA\u003c\/td\u003e\n\u003c\/tr\u003e\n\u003ctr\u003e\n\u003ctd\u003ePLANO:\u003c\/td\u003e\n\u003ctd\u003eCarbono 3k\u003c\/td\u003e\n\u003c\/tr\u003e\n\u003ctr\u003e\n\u003ctd\u003ePESO:\u003c\/td\u003e\n\u003ctd\u003e355 gr \/ 365 gr\u003c\/td\u003e\n\u003c\/tr\u003e\n\u003ctr\u003e\n\u003ctd\u003eACABADO:\u003c\/td\u003e\n\u003ctd\u003eMate\u003c\/td\u003e\n\u003c\/tr\u003e\n\u003c\/tbody\u003e\n\u003c\/table\u003e\n\u003c\/div\u003e\n\u003cdiv class=\"circle-metrics\"\u003e\n\u003cdiv\u003e\n\u003cdiv class=\"circle-label\"\u003ePotencia\u003c\/div\u003e\n\u003cdiv class=\"circle\"\u003e\u003cspan\u003e95\u003cspan style=\"font-size: 14px;\"\u003e%\u003c\/span\u003e\u003c\/span\u003e\u003c\/div\u003e\n\u003c\/div\u003e\n\u003cdiv\u003e\n\u003cdiv class=\"circle-label\"\u003eControl\u003c\/div\u003e\n\u003cdiv class=\"circle control\"\u003e\u003cspan\u003e100\u003cspan style=\"font-size: 14px;\"\u003e%\u003c\/span\u003e\u003c\/span\u003e\u003c\/div\u003e\n\u003c\/div\u003e\n\u003c\/div\u003e\n\u003c\/div\u003e\n\u003c\/div\u003e\n\u003c!-- DESCRIPCIÓN --\u003e\n\u003cdiv id=\"content2\"\u003e\n\u003cp\u003eLa \u003cstrong\u003eVairo Grapheno Speed\u003c\/strong\u003e es una pala pensada para jugadores de pádel de \u003cstrong\u003enivel avanzado y profesionales\u003c\/strong\u003e que en los partidos o entrenamientos opten más por un \u003cstrong\u003ejuego de control y potencia\u003c\/strong\u003e y disfruten defendiendo hasta los puntos más complejos.\u003c\/p\u003e\n\u003cp\u003ePresenta una \u003cstrong\u003eformato gota con un balance medio\u003c\/strong\u003e, unas características que la convierten en la opción perfecta para aquellos que busquen un \u003cstrong\u003ebuen control y potencia de la bola\u003c\/strong\u003e, así como una gran facilidad de manejo y maniobrabilidad.\u003c\/p\u003e\n\u003c\/div\u003e\n\u003c!-- TECNOLOGÍA --\u003e\n\u003cdiv id=\"content3\"\u003e\n\u003cul\u003e\n\u003cli\u003e\n\u003cstrong\u003eREINFORCED ZONE:\u003c\/strong\u003e Doble estructura de carbono en los laterales del corazón de la pala: minimiza las torsiones y vibraciones producidas con el impacto de la bola.\u003c\/li\u003e\n\u003cli\u003e\n\u003cstrong\u003eSPEED SHOT:\u003c\/strong\u003e Arquitectura interna triangular que genera un corazón rígido y un sweet spot un 20% mayor.\u003c\/li\u003e\n\u003cli\u003e\n\u003cstrong\u003eCARBON COMPOSITE:\u003c\/strong\u003e Material rígido y ligero que mejora control y rendimiento.\u003c\/li\u003e\n\u003cli\u003e\n\u003cstrong\u003eDUAL INTEGRATED COLUMNS:\u003c\/strong\u003e Tubos de carbono en el corazón que aumentan la estabilidad y dominio de la pala.\u003c\/li\u003e\n\u003cli\u003e\n\u003cstrong\u003eUNDERGRIP ABSORPTION:\u003c\/strong\u003e Malla “Expandex PC16” que aporta mayor confort en el grip.\u003c\/li\u003e\n\u003cli\u003e\n\u003cstrong\u003eSPOT ZONE:\u003c\/strong\u003e Láminas de fibra con abrasivo aplicadas para mejorar el efecto y la superficie de contacto.\u003c\/li\u003e\n\u003cli\u003e\n\u003cstrong\u003eABSORPTION SHOCK:\u003c\/strong\u003e Sistema antivibratorio exclusivo de Vairo que reduce notablemente las vibraciones.\u003c\/li\u003e\n\u003cli\u003e\n\u003cstrong\u003eABSORVENT GRIP:\u003c\/strong\u003e Gomas blandas que evitan que la pala resbale, ofreciendo gran absorción y agarre.\u003c\/li\u003e\n\u003c\/ul\u003e\n\u003c\/div\u003e\n\u003c\/div\u003e\n\u003c\/div\u003e","published_at":"2026-05-20T16:26:04-03:00","created_at":"2025-07-03T08:59:23-03:00","updated_at":"2026-06-12T15:10:32-03:00","vendor":"Vairo","product_type":"","tags":["Formato Híbrido","Grapheno Speed Classic 9.1","Palas de Padel Vairo - Argentina \u003e Professional Premium"],"variants":[{"id":48268917997773,"title":"Default Title","option1":"Default Title","option2":null,"option3":null,"sku":"608001134 0101","requires_shipping":true,"taxable":true,"featured_image":null,"available":false,"price":"373000.00","grams":400,"compare_at_price":"0.00","position":1,"product_id":9032067678413,"created_at":"2025-07-03T08:59:24-03:00","updated_at":"2026-06-12T15:10:32-03:00"}],"images":[{"id":54956594331853,"created_at":"2026-04-15T16:49:58-03:00","position":1,"updated_at":"2026-04-15T16:50:13-03:00","product_id":9032067678413,"variant_ids":[],"src":"https:\/\/cdn.shopify.com\/s\/files\/1\/0653\/4745\/3133\/files\/GraphenoSpeedClassic9.1.png?v=1776282613","width":1080,"height":1080},{"id":54743897571533,"created_at":"2026-01-15T12:27:39-03:00","position":2,"updated_at":"2026-04-15T16:50:13-03:00","product_id":9032067678413,"variant_ids":[],"src":"https:\/\/cdn.shopify.com\/s\/files\/1\/0653\/4745\/3133\/files\/FOTOGRAPHENOSPEEDCLASSICCUADRADO.jpg?v=1776282613","width":1000,"height":1000},{"id":54215385612493,"created_at":"2025-07-03T08:59:24-03:00","position":3,"updated_at":"2026-04-15T16:50:13-03:00","product_id":9032067678413,"variant_ids":[],"src":"https:\/\/cdn.shopify.com\/s\/files\/1\/0653\/4745\/3133\/files\/GRAPHENO-SPEED-PERFIL.jpg?v=1776282613","width":1080,"height":1080},{"id":54215385645261,"created_at":"2025-07-03T08:59:24-03:00","position":4,"updated_at":"2026-04-15T16:50:13-03:00","product_id":9032067678413,"variant_ids":[],"src":"https:\/\/cdn.shopify.com\/s\/files\/1\/0653\/4745\/3133\/files\/GRAPHENO-SPEED-LADO2.jpg?v=1776282613","width":1080,"height":1080},{"id":54215385678029,"created_at":"2025-07-03T08:59:24-03:00","position":5,"updated_at":"2026-04-15T16:50:13-03:00","product_id":9032067678413,"variant_ids":[],"src":"https:\/\/cdn.shopify.com\/s\/files\/1\/0653\/4745\/3133\/files\/GRAPHENO-SPEED-LADO1.jpg?v=1776282613","width":1080,"height":1080},{"id":55032830755021,"created_at":"2026-05-28T11:18:43-03:00","position":6,"updated_at":"2026-05-28T11:18:44-03:00","product_id":9032067678413,"variant_ids":[],"src":"https:\/\/cdn.shopify.com\/s\/files\/1\/0653\/4745\/3133\/files\/GRAPHENOCLASSICSPEED05.jpg?v=1779977924","width":1080,"height":1080},{"id":55032830787789,"created_at":"2026-05-28T11:18:43-03:00","position":7,"updated_at":"2026-05-28T11:18:44-03:00","product_id":9032067678413,"variant_ids":[],"src":"https:\/\/cdn.shopify.com\/s\/files\/1\/0653\/4745\/3133\/files\/GRAPHENOCLASSICSPEED09.jpg?v=1779977924","width":1080,"height":1080},{"id":55032830820557,"created_at":"2026-05-28T11:18:43-03:00","position":8,"updated_at":"2026-05-28T11:18:45-03:00","product_id":9032067678413,"variant_ids":[],"src":"https:\/\/cdn.shopify.com\/s\/files\/1\/0653\/4745\/3133\/files\/GRAPHENOCLASSICSPEED08.jpg?v=1779977925","width":1080,"height":1080},{"id":55032830853325,"created_at":"2026-05-28T11:18:43-03:00","position":9,"updated_at":"2026-05-28T11:18:44-03:00","product_id":9032067678413,"variant_ids":[],"src":"https:\/\/cdn.shopify.com\/s\/files\/1\/0653\/4745\/3133\/files\/GRAPHENOCLASSICSPEED07.jpg?v=1779977924","width":1080,"height":1080},{"id":55032830886093,"created_at":"2026-05-28T11:18:43-03:00","position":10,"updated_at":"2026-05-28T11:18:44-03:00","product_id":9032067678413,"variant_ids":[],"src":"https:\/\/cdn.shopify.com\/s\/files\/1\/0653\/4745\/3133\/files\/GRAPHENOCLASSICSPEED06.jpg?v=1779977924","width":1080,"height":1080}],"options":[{"name":"Title","position":1,"values":["Default Title"]}]},{"id":9032065614029,"title":"Grapheno Turbo Confort","handle":"grapheno-turbo-confort","body_html":"\u003cp\u003e\u003cstrong\u003eIncluye:\u003c\/strong\u003e Funda de tela con correas para usar como mochila\u003c\/p\u003e\n\u003cp\u003e\u003cstrong\u003eDiseñada para ofrecer comodidad y rendimiento\u003c\/strong\u003e, presenta una forma redonda que brinda un punto dulce amplio y un control excepcional en cada golpe. Con un balance bajo que permite una maniobrabilidad óptima en la pista.\u003c\/p\u003e\n\u003cdiv class=\"highlight-box\"\u003e\n\u003cstrong\u003eNivel de Juego:\u003c\/strong\u003e Avanzado \/ Competición   |   \u003cstrong\u003eTipo de Juego:\u003c\/strong\u003e Control\u003c\/div\u003e\n\u003cdiv class=\"tabs-minimal\"\u003e\n\u003cinput checked id=\"tab1\" name=\"tabs\" type=\"radio\"\u003e \u003cinput id=\"tab2\" name=\"tabs\" type=\"radio\"\u003e \u003cinput id=\"tab3\" name=\"tabs\" type=\"radio\"\u003e\n\u003cdiv class=\"tab-labels\"\u003e\n\u003clabel for=\"tab1\"\u003eCARACTERÍSTICAS\u003c\/label\u003e \u003clabel for=\"tab2\"\u003eDESCRIPCIÓN\u003c\/label\u003e \u003clabel for=\"tab3\"\u003eTECNOLOGÍA\u003c\/label\u003e\n\u003c\/div\u003e\n\u003cdiv class=\"tab-content\"\u003e\n\u003c!-- CARACTERÍSTICAS --\u003e\n\u003cdiv id=\"content1\"\u003e\n\u003cdiv class=\"caracteristicas-grid\"\u003e\n\u003cdiv\u003e\n\u003ctable\u003e\n\u003ctbody\u003e\n\u003ctr\u003e\n\u003ctd\u003eFORMA:\u003c\/td\u003e\n\u003ctd\u003eRedonda\u003c\/td\u003e\n\u003c\/tr\u003e\n\u003ctr\u003e\n\u003ctd\u003eBALANCE:\u003c\/td\u003e\n\u003ctd\u003eBajo\u003c\/td\u003e\n\u003c\/tr\u003e\n\u003ctr\u003e\n\u003ctd\u003eMARCO:\u003c\/td\u003e\n\u003ctd\u003eFibra de Vidrio con refuerzos de Carbono 3K\u003c\/td\u003e\n\u003c\/tr\u003e\n\u003ctr\u003e\n\u003ctd\u003eNÚCLEO:\u003c\/td\u003e\n\u003ctd\u003eFoam Inglés\u003c\/td\u003e\n\u003c\/tr\u003e\n\u003ctr\u003e\n\u003ctd\u003ePLANO:\u003c\/td\u003e\n\u003ctd\u003eFibra de carbono\u003c\/td\u003e\n\u003c\/tr\u003e\n\u003ctr\u003e\n\u003ctd\u003ePESO:\u003c\/td\u003e\n\u003ctd\u003e360 gr \/ 370 gr\u003c\/td\u003e\n\u003c\/tr\u003e\n\u003ctr\u003e\n\u003ctd\u003eACABADO:\u003c\/td\u003e\n\u003ctd\u003eMate\u003c\/td\u003e\n\u003c\/tr\u003e\n\u003c\/tbody\u003e\n\u003c\/table\u003e\n\u003c\/div\u003e\n\u003cdiv class=\"circle-metrics\"\u003e\n\u003cdiv\u003e\n\u003cdiv class=\"circle-label\"\u003ePotencia\u003c\/div\u003e\n\u003cdiv class=\"circle\"\u003e\u003cspan\u003e95\u003cspan style=\"font-size: 14px;\"\u003e%\u003c\/span\u003e\u003c\/span\u003e\u003c\/div\u003e\n\u003c\/div\u003e\n\u003cdiv\u003e\n\u003cdiv class=\"circle-label\"\u003eControl\u003c\/div\u003e\n\u003cdiv class=\"circle control\"\u003e\u003cspan\u003e100\u003cspan style=\"font-size: 14px;\"\u003e%\u003c\/span\u003e\u003c\/span\u003e\u003c\/div\u003e\n\u003c\/div\u003e\n\u003c\/div\u003e\n\u003c\/div\u003e\n\u003c\/div\u003e\n\u003c!-- DESCRIPCIÓN --\u003e\n\u003cdiv id=\"content2\"\u003e\n\u003cp\u003eSu \u003cstrong\u003emarco de carbono y fibra de vidrio\u003c\/strong\u003e garantiza una estructura ligera y resistente, proporcionando potencia y durabilidad sin comprometer la maniobrabilidad.\u003c\/p\u003e\n\u003cp\u003eEquipada con un \u003cstrong\u003enúcleo de foam inglés\u003c\/strong\u003e que ofrece un tacto suave y una excelente respuesta en cada movimiento, asegurando una experiencia de juego cómoda y satisfactoria.\u003c\/p\u003e\n\u003cp\u003eEl \u003cstrong\u003eplano de fibra de carbono\u003c\/strong\u003e añade potencia adicional a tus golpes, permitiéndote dominar la pista con facilidad. Con un peso entre 360 gramos a 370 gramos y acabado mate para un estilo elegante y sofisticado.\u003c\/p\u003e\n\u003c\/div\u003e\n\u003c!-- TECNOLOGÍA --\u003e\n\u003cdiv id=\"content3\"\u003e\n\u003cul\u003e\n\u003cli\u003e\n\u003cstrong\u003eSKIN TECH HEXAGON:\u003c\/strong\u003e Patrón en relieve hexagonal que mejora el agarre y control en cada golpe.\u003c\/li\u003e\n\u003cli\u003e\n\u003cstrong\u003eREINFORCED ZONE:\u003c\/strong\u003e Refuerzos de carbono en los laterales del corazón que minimizan vibraciones.\u003c\/li\u003e\n\u003cli\u003e\n\u003cstrong\u003eSPEED SHOT:\u003c\/strong\u003e Arquitectura interna que amplía el sweet spot en un 20%.\u003c\/li\u003e\n\u003cli\u003e\n\u003cstrong\u003eANTISHOCK COVER:\u003c\/strong\u003e Protector de nylon resistente y flexible ante impactos.\u003c\/li\u003e\n\u003cli\u003e\n\u003cstrong\u003eCARBON COMPOSITE:\u003c\/strong\u003e Mayor rigidez y ligereza para potenciar control y rendimiento.\u003c\/li\u003e\n\u003cli\u003e\n\u003cstrong\u003eUNDERGRIP ABSORPTION:\u003c\/strong\u003e Malla interna que aporta suavidad y confort en el agarre.\u003c\/li\u003e\n\u003cli\u003e\n\u003cstrong\u003eCONSTRUCTION GRAPH:\u003c\/strong\u003e Integración de grafeno para máxima potencia con mínimo peso.\u003c\/li\u003e\n\u003cli\u003e\n\u003cstrong\u003eABSORPTION SHOCK:\u003c\/strong\u003e Sistema antivibratorio dual exclusivo de Vairo.\u003c\/li\u003e\n\u003cli\u003e\n\u003cstrong\u003eABSORVENT GRIP:\u003c\/strong\u003e Grip de alta absorción y excelente agarre.\u003c\/li\u003e\n\u003cli\u003e\n\u003cstrong\u003eFOAM:\u003c\/strong\u003e Material que mejora el control y amortiguación en cada golpe.\u003c\/li\u003e\n\u003c\/ul\u003e\n\u003c\/div\u003e\n\u003c\/div\u003e\n\u003c\/div\u003e","published_at":"2025-07-03T08:56:24-03:00","created_at":"2025-07-03T08:56:26-03:00","updated_at":"2026-06-12T15:10:32-03:00","vendor":"Vairo","product_type":"","tags":["Carbono 3K","Foam Inglés","Formato Redondo","Grapheno Turbo Confort","Medio-Bajo","Palas de Padel Vairo - Argentina \u003e Professional Series","Redonda","Refuerzo Carbono 3K"],"variants":[{"id":48268915933389,"title":"Default Title","option1":"Default Title","option2":null,"option3":null,"sku":"601001640 0301","requires_shipping":true,"taxable":true,"featured_image":{"id":54215366017229,"product_id":9032065614029,"position":1,"created_at":"2025-07-03T08:56:26-03:00","updated_at":"2025-07-03T08:56:26-03:00","alt":null,"width":1080,"height":1080,"src":"https:\/\/cdn.shopify.com\/s\/files\/1\/0653\/4745\/3133\/files\/TURBO-CONFOR