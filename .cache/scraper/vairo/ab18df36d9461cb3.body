}]},{"id":9032068726989,"title":"Kit Paleta Across Yellow + Paletero Across Yellow","handle":"kit-paleta-acqua-sil-campus-paletero-team","body_html":"\u003cp\u003e\u003cbr\u003e\u003c\/p\u003e\n\u003cp\u003e \u003c\/p\u003e\n\u003cp\u003e \u003c\/p\u003e","published_at":"2025-11-19T16:37:26-03:00","created_at":"2025-07-03T09:01:18-03:00","updated_at":"2026-06-12T15:10:32-03:00","vendor":"Vairo","product_type":"","tags":["Combos"],"variants":[{"id":48268919046349,"title":"Default Title","option1":"Default Title","option2":null,"option3":null,"sku":"301001021","requires_shipping":true,"taxable":true,"featured_image":null,"available":true,"price":"308800.00","grams":400,"compare_at_price":"309000.00","position":1,"product_id":9032068726989,"created_at":"2025-07-03T09:01:18-03:00","updated_at":"2026-06-12T15:10:32-03:00"}],"images":[{"id":54646207447245,"created_at":"2025-11-18T15:36:26-03:00","position":1,"updated_at":"2025-11-18T15:36:27-03:00","product_id":9032068726989,"variant_ids":[],"src":"https:\/\/cdn.shopify.com\/s\/files\/1\/0653\/4745\/3133\/files\/CONBOACROSS.jpg?v=1763490987","width":1080,"height":1080}],"options":[{"name":"Title","position":1,"values":["Default Title"]}]},{"id":9113024069837,"title":"Kit Paleta Compact Signature + Mochila Compact Signature","handle":"kit-pala-y-mochila-signature","body_html":"\u003cp data-start=\"32\" data-end=\"255\"\u003eDiseño, funcionalidad y rendimiento en una combinación perfecta para llevar tu juego a otro nivel.\u003cbr data-start=\"130\" data-end=\"133\"\u003eEste kit reúne dos productos pensados para jugadores que buscan practicidad, estilo y calidad dentro y fuera de la cancha.\u003c\/p\u003e\n\u003cp data-start=\"257\" data-end=\"520\"\u003eLa \u003cstrong data-start=\"260\" data-end=\"281\"\u003eCompact Signature\u003c\/strong\u003e ofrece un juego equilibrado y versátil, ideal para quienes buscan control, confort y una excelente respuesta en cada golpe. Su diseño moderno y materiales de alta calidad brindan una experiencia sólida y confiable durante todo el partido.\u003c\/p\u003e\n\u003cp data-start=\"522\" data-end=\"776\"\u003eLa \u003cstrong data-start=\"525\" data-end=\"554\"\u003eMochila Compact Signature\u003c\/strong\u003e complementa el kit con un diseño cómodo y funcional, perfecta para transportar tu paleta, accesorios y objetos personales de manera organizada y segura. Ideal para acompañarte tanto en entrenamientos como en competencias.\u003c\/p\u003e","published_at":"2026-05-11T11:29:21-03:00","created_at":"2026-05-08T15:51:18-03:00","updated_at":"2026-06-12T15:10:32-03:00","vendor":"Vairo Padel","product_type":"","tags":["Combos"],"variants":[{"id":48562630656205,"title":"Default Title","option1":"Default Title","option2":null,"option3":null,"sku":"301001005","requires_shipping":true,"taxable":true,"featured_image":null,"available":true,"price":"404600.00","grams":0,"compare_at_price":"476000.00","position":1,"product_id":9113024069837,"created_at":"2026-05-08T15:51:18-03:00","updated_at":"2026-06-12T15:10:32-03:00"}],"images":[{"id":55009054392525,"created_at":"2026-05-08T15:56:19-03:00","position":1,"updated_at":"2026-05-08T15:56:21-03:00","product_id":9113024069837,"variant_ids":[],"src":"https:\/\/cdn.shopify.com\/s\/files\/1\/0653\/4745\/3133\/files\/COMBO_COMPACT_SIGNATURE.jpg?v=1778266581","width":1080,"height":1080}],"options":[{"name":"Title","position":1,"values":["Default Title"]}]},{"id":9090399961293,"title":"Lentes Aero Polarizado","handle":"lentes-aero-polarizado","body_html":"\u003cul class=\"list-chevron\"\u003e\n\u003cli\u003e\n\u003cp\u003e\u003cstrong\u003eDiseñadas para el deporte y la aventura.\u003c\/strong\u003e\u003cspan\u003e \u003c\/span\u003eEstas gafas ofrecen protección total y confort en todo momento.\u003c\/p\u003e\n\u003cul class=\"list-chevron\"\u003e\n\u003cli\u003e\u003cstrong\u003eIdeales para ciclismo, running, triatlón y deportes outdoor.\u003c\/strong\u003e\u003c\/li\u003e\n\u003cli\u003e\n\u003cstrong\u003eVersátiles:\u003c\/strong\u003e\u003cspan\u003e \u003c\/span\u003eAdaptables al sol, neblina, lluvia o noche.\u003c\/li\u003e\n\u003cli\u003e\u003cstrong\u003eAptas para competición, entrenamiento, ruta o montaña.\u003c\/strong\u003e\u003c\/li\u003e\n\u003cli\u003e\n\u003cstrong\u003eIncluye:\u003c\/strong\u003e\u003cspan\u003e \u003c\/span\u003eMontura, lente montada, lente de recambio, estuche rígido Vairo, paño de microfibra y manual de certificaciones.\u003c\/li\u003e\n\u003c\/ul\u003e\n.\u003c\/li\u003e\n\u003c\/ul\u003e\n\u003cdiv class=\"tabs-minimal\"\u003e\n\u003cinput checked id=\"tab1\" name=\"tabs\" type=\"radio\"\u003e \u003cinput id=\"tab2\" name=\"tabs\" type=\"radio\"\u003e\n\u003cdiv class=\"tab-labels\"\u003e\n\u003clabel for=\"tab1\"\u003eCARACTERÍSTICAS\u003c\/label\u003e \u003clabel for=\"tab2\"\u003eTECNOLOGÍA\u003c\/label\u003e\n\u003c\/div\u003e\n\u003cdiv class=\"tab-content\"\u003e\n\u003cdiv id=\"content1\"\u003e\n\u003cul class=\"list-chevron prose\"\u003e\n\u003cli\u003e\n\u003cstrong\u003eMaterial:\u003c\/strong\u003e\u003cspan\u003e \u003c\/span\u003eLente de\u003cspan\u003e \u003c\/span\u003e\u003cstrong\u003epolicarbonato puro\u003c\/strong\u003e\u003cspan\u003e \u003c\/span\u003econ\u003cspan\u003e \u003c\/span\u003e\u003cstrong\u003etecnología REVO\u003c\/strong\u003e.\u003c\/li\u003e\n\u003cli\u003e\n\u003cstrong\u003eProtección:\u003c\/strong\u003e\u003cspan\u003e \u003c\/span\u003e\u003cstrong\u003eUV400 total\u003c\/strong\u003e\u003cspan\u003e \u003c\/span\u003e(bloquea\u003cspan\u003e \u003c\/span\u003e\u003cstrong\u003eUVA\u003c\/strong\u003e,\u003cspan\u003e \u003c\/span\u003e\u003cstrong\u003eUVB\u003c\/strong\u003e\u003cspan\u003e \u003c\/span\u003ey luz dañina).\u003c\/li\u003e\n\u003cli\u003e\n\u003cstrong\u003eResistencia:\u003c\/strong\u003e\u003cspan\u003e \u003c\/span\u003eAlta resistencia a impactos (\u003cstrong\u003eanti-shock\u003c\/strong\u003e).\u003c\/li\u003e\n\u003cli\u003e\n\u003cstrong\u003eTransmisión de luz:\u003c\/strong\u003e\u003cspan\u003e \u003c\/span\u003eDel\u003cspan\u003e \u003c\/span\u003e\u003cstrong\u003e8% al 93%\u003c\/strong\u003e\u003cspan\u003e \u003c\/span\u003esegún el tipo de lente.\u003c\/li\u003e\n\u003cli\u003e\n\u003cstrong\u003eLentes intercambiables:\u003c\/strong\u003e\u003cspan\u003e \u003c\/span\u003eAdaptables a distintas condiciones.\u003c\/li\u003e\n\u003cli\u003e\n\u003cstrong\u003eMontura ergonómica:\u003c\/strong\u003e\u003cspan\u003e \u003c\/span\u003eLente envolvente y\u003cspan\u003e \u003c\/span\u003e\u003cstrong\u003evisión periférica\u003c\/strong\u003e.\u003c\/li\u003e\n\u003cli\u003e\n\u003cstrong\u003ePatillas antideslizantes\u003c\/strong\u003e\u003cspan\u003e \u003c\/span\u003ey\u003cspan\u003e \u003c\/span\u003e\u003cstrong\u003epads nasales\u003c\/strong\u003e\u003cspan\u003e \u003c\/span\u003econ ventilación superior.\u003c\/li\u003e\n\u003cli\u003e\n\u003cstrong\u003ePeso ligero\u003c\/strong\u003e\u003cspan\u003e \u003c\/span\u003ey gran confort.\u003cbr\u003e\n\u003c\/li\u003e\n\u003c\/ul\u003e\n\u003c\/div\u003e\n\u003c!-- TECNOLOGÍA --\u003e\n\u003cdiv id=\"content2\"\u003e\n\u003cul\u003e\n\u003cli\u003e\n\u003cstrong\u003eDiseño de 7 capas:\u003c\/strong\u003e\u003cspan\u003e \u003c\/span\u003eLentes multicapa para mayor protección y durabilidad.\u003c\/li\u003e\n\u003cli\u003e\n\u003cstrong\u003ePolarizado real:\u003c\/strong\u003e\u003cspan\u003e \u003c\/span\u003eElimina reflejos y reduce la fatiga visual.\u003c\/li\u003e\n\u003cli\u003e\n\u003cstrong\u003eTecnología REVO:\u003c\/strong\u003e\u003cspan\u003e \u003c\/span\u003eMejora la visión y protege contra la luz intensa.\u003c\/li\u003e\n\u003cli\u003e\n\u003cstrong\u003eMontura ergonómica:\u003c\/strong\u003e\u003cspan\u003e \u003c\/span\u003eAjuste óptimo y cómodo para largas jornadas.\u003c\/li\u003e\n\u003cli\u003e\n\u003cstrong\u003eVentilación superior:\u003c\/strong\u003e\u003cspan\u003e \u003c\/span\u003eEvita el empañamiento y mejora el flujo de aire.